PORT=3000
APP_BASE_URL=https://your-app.railway.app
NODE_ENV=production

# Shopify
SHOPIFY_SHOP=widgetco-inc.myshopify.com
SHOPIFY_STORE_DOMAIN=widgetco.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-10
SHOPIFY_CARRIER_SERVICE_NAME=Precision Shipping

# Admin access (comma-separated)
ALLOWED_ADMIN_EMAILS=jg@widgetco.com,lgerkey@widgetco.com
SESSION_TOKEN_SECRET=replace-with-a-long-random-string
LOCAL_ADMIN_LABEL=jg@widgetco.com

# Ship-from / origin address
ORIGIN_NAME=WidgetCo
ORIGIN_ADDRESS=123 Warehouse Blvd
ORIGIN_CITY=Your City
ORIGIN_STATE=TX
ORIGIN_ZIP=75001

# FedEx REST API  (developer.fedex.com)
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT_NUMBER=

# UPS REST API  (developer.ups.com)
# Shared OAuth credentials (one app in UPS Developer Portal)
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
# Shipper account numbers — one per service group
UPS_GROUND_ACCOUNT=        # Account used for UPS Ground
UPS_2DAY_ACCOUNT=          # Account used for UPS 2-Day Air
UPS_GROUND_SAVER_ACCOUNT=  # Account used for UPS Ground Saver (<1 lb and +1 lb)

# USPS Web Tools API  (developer.usps.com)
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=
