<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
  <title>WidgetCo Precision Shipping</title>
  <link rel="stylesheet" href="/styles.css" />
  <style>
    .est-section { margin-top: 20px; }
    .est-section-label { font-size: 11px; text-transform: uppercase; letter-spacing: .08em; color: var(--muted); margin: 0 0 12px; font-weight: 700; }
    .est-sku-header { display: grid; grid-template-columns: 1fr 130px 130px 110px 32px; gap: 8px; padding: 4px 0 6px; font-size: 11px; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); border-bottom: 1px solid var(--line); }
    .est-row { display: grid; grid-template-columns: 1fr 130px 130px 110px 32px; gap: 8px; align-items: center; padding: 8px 0; border-bottom: 1px solid var(--line); }
    .est-row:last-child { border-bottom: none; }
    .est-sku-wrap { position: relative; }
    .est-sku-input, .est-qty-input, .est-manual-weight { width: 100%; border: 1.5px solid #d1d5db; border-radius: 8px; padding: 11px 12px; font: inherit; font-size: 14px; box-sizing: border-box; background: #fff; }
    .est-sku-input:focus, .est-qty-input:focus, .est-manual-weight:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(17,24,39,.08); }
    .est-qty-input { text-align: center; }
    .est-unit-g { font-size: 12px; color: var(--muted); }
    .est-unit-g.found { color: var(--pill-on-text); font-weight: 600; }
    .est-row-total { font-size: 13px; font-weight: 600; color: var(--text); }
    .est-remove-btn { background: none; border: none; cursor: pointer; color: var(--muted); font-size: 16px; padding: 2px 6px; border-radius: 4px; transition: color .15s; line-height: 1; }
    .est-remove-btn:hover { color: #dc2626; }
    .est-add-btn { margin-top: 10px; background: rgba(17,24,39,.04); border: 1px dashed var(--line); border-radius: 8px; color: var(--muted); font: inherit; font-size: 13px; cursor: pointer; padding: 8px 16px; width: 100%; transition: background .15s; }
    .est-add-btn:hover { background: rgba(17,24,39,.08); color: var(--text); }
    .est-ac { position: absolute; top: 100%; left: 0; right: 0; background: #fff; border: 1px solid var(--line); border-radius: 8px; z-index: 100; max-height: 180px; overflow-y: auto; margin-top: 2px; box-shadow: 0 8px 24px rgba(17,24,39,.12); display: none; }
    .est-ac-item { padding: 8px 12px; font-size: 13px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
    .est-ac-item:hover { background: var(--bg); }
    .est-results-summary { margin: 16px 0 12px; }
    .est-results-summary table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .est-results-summary td { padding: 3px 8px 3px 0; color: var(--text); vertical-align: top; }
    .est-results-summary td:first-child { color: var(--muted); width: 140px; }
    .est-rates-label { font-size: 11px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); margin: 16px 0 8px; }
    .est-rates-list { display: flex; flex-direction: column; gap: 7px; }
    .est-rate-card { display: flex; align-items: center; gap: 12px; padding: 10px 14px; border: 1px solid var(--line); border-radius: 8px; background: #fff; }
    .est-rate-carrier { display: inline-flex; align-items: center; justify-content: center; width: 60px; height: 32px; border-radius: 6px; background: #fff; border: 1px solid #e5e7eb; flex-shrink: 0; overflow: hidden; }
    .est-rate-carrier img { max-width: 56px; max-height: 28px; object-fit: contain; display: block; }
    .est-rate-service { flex: 1; font-size: 14px; color: var(--text); }
    .est-rate-price { font-size: 15px; font-weight: 700; color: var(--text); white-space: nowrap; }
    .est-rate-days { font-size: 13px; color: var(--muted); white-space: nowrap; min-width: 80px; text-align: right; }
      .est-residential-wrap { margin-top: 6px; }
      .est-residential-label { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--muted); cursor: pointer; }
      .est-residential-label input { cursor: pointer; }
    .est-no-rates { color: var(--muted); font-size: 13px; margin-top: 8px; }
    .est-ac-wt { font-size: 11px; color: var(--pill-on-text); font-weight: 600; }
    .est-totals { display: flex; flex-wrap: wrap; gap: 20px; background: var(--bg); border: 1px solid var(--line); border-radius: 12px; padding: 12px 16px; margin-top: 16px; margin-bottom: 4px; font-size: 13px; color: var(--muted); }
    .est-total-item strong { color: var(--text); margin-left: 4px; }
    .est-label { display: grid; gap: 6px; }
    .est-label-text { font-size: 13px; color: var(--text); font-weight: 600; }
    .est-label input { width: 100%; border: 1.5px solid #d1d5db; border-radius: 8px; padding: 12px 14px; font: inherit; font-size: 14px; box-sizing: border-box; background: #fff; color: var(--text); transition: border-color .15s, box-shadow .15s; }
    .est-label input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(17,24,39,.1); }
    .est-label input::placeholder { color: #9ca3af; }
    .acct-label { font-size: 11px; font-weight: 600; color: var(--muted); margin: 6px 0 2px; letter-spacing: .04em; }
    /* ── Weights table ─────────────────────────────────────────────────────────── */
    .weights-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 4px; }
    .weights-table th { text-align: left; padding: 8px 12px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); background: var(--bg); border-bottom: 2px solid var(--line); white-space: nowrap; }
    .weights-table td { padding: 7px 12px; border-bottom: 1px solid var(--line); vertical-align: middle; }
    .weights-table tbody tr:last-child td { border-bottom: none; }
    .weights-table tbody tr:hover { background: var(--bg); }
    .weights-table td:last-child, .weights-table th:last-child { text-align: center; }
    .sku-search-row input { font-size: 13px; padding: 7px 12px; width: 260px; border-radius: 10px; }
  
    button.pill { border: none; font: inherit; outline: none; cursor: pointer; }
    .toggle { cursor: pointer; }
  
    /* ── Carrier two-column service layout ─────────────────────────────────────── */
    .carrier-head-right { display: flex; align-items: center; gap: 10px; }
    .carrier-status-label { font-size: 12px; font-weight: 600; color: var(--muted); }
    .carrier-toggle { flex-shrink: 0; }
    .services-columns { display: grid; grid-template-columns: 1fr 1fr; gap: 0 24px; margin-top: 8px; }
    .services-col { }
    .svc-col-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); margin: 8px 0 4px; border-bottom: 1px solid var(--line); padding-bottom: 4px; }
    .svc-col-empty { color: var(--muted); font-size: 13px; padding: 6px 0; }
  
  /* Individual-box toggle switch */
  .toggle-switch { position: relative; display: inline-block; width: 36px; height: 20px; }
  .toggle-switch input { opacity: 0; width: 0; height: 0; }
  .toggle-slider {
    position: absolute; cursor: pointer; inset: 0;
    background: #d1d5db; border-radius: 20px; transition: .2s;
  }
  .toggle-slider:before {
    content: ""; position: absolute;
    width: 14px; height: 14px; left: 3px; bottom: 3px;
    background: white; border-radius: 50%; transition: .2s;
  }
  .toggle-switch input:checked + .toggle-slider { background: #86efac; }
  .toggle-switch input:checked + .toggle-slider:before { transform: translateX(16px); }
  .toggle-switch input:disabled + .toggle-slider { opacity: 0.5; cursor: wait; }
    /* Package selector */
    .pkg-selector-row { margin-bottom: .75rem; }
    .pkg-select { width: 100%; padding: .45rem .6rem; border: 1px solid #d1d5db; border-radius: 6px; font-size: .85rem; background: #fff; }
    .grid.four { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: .75rem; }
    .btn-danger { background: #fef2f2; color: #dc2626; border: 1px solid #fca5a5; }
    .btn-danger:hover { background: #fee2e2; }
    .muted-desc { color: #6b7280; font-size: .875rem; margin-top: -.25rem; margin-bottom: 1rem; }
</style>
<script>
// ── Shipping Schedule & Holiday Data (single source of truth) ───────────────
const BIZ_HOLIDAYS = [
  // 2026 — FedEx/UPS observed holidays
  { date: '1/1',   label: "New Year's Day" },
  { date: '1/19',  label: 'MLK Jr. Day' },
  { date: '5/25',  label: 'Memorial Day' },
  { date: '7/4',   label: 'Independence Day' },
  { date: '8/31',  label: 'Labor Day' },
  { date: '11/26', label: 'Thanksgiving' },
  { date: '12/25', label: 'Christmas' },
  // 2027 — FedEx/UPS observed holidays
  { date: '1/1',   label: "New Year's Day" },
  { date: '1/18',  label: 'MLK Jr. Day' },
  { date: '5/31',  label: 'Memorial Day' },
  { date: '7/5',   label: 'Independence Day (observed)' },
  { date: '9/6',   label: 'Labor Day' },
  { date: '11/25', label: 'Thanksgiving' },
  { date: '12/24', label: 'Christmas (observed)' },
];
const SHIP_SCHEDULE = [
  { day: 'Monday',    ships: true,  cutoff: '4:00 PM CST' },
  { day: 'Tuesday',   ships: true,  cutoff: '4:00 PM CST' },
  { day: 'Wednesday', ships: true,  cutoff: '4:00 PM CST' },
  { day: 'Thursday',  ships: true,  cutoff: '4:00 PM CST' },
  { day: 'Friday',    ships: true,  cutoff: '4:00 PM CST' },
  { day: 'Saturday',  ships: false, cutoff: null },
  { day: 'Sunday',    ships: false, cutoff: null },
];
</script>
</head>
<body>
<main class="shell">
  <aside class="sidebar">
    <div>
      <strong>Precision Shipping</strong>
      <p class="muted">WidgetCo custom shipping app</p>
    </div>
    <nav id="pageNav">
      <a href="#overview" class="nav-link">Overview</a>
      <a href="#methods" class="nav-link">Shipping methods</a>
      <a href="#rules" class="nav-link">Rules</a>
      <a href="#preview" class="nav-link">Estimator</a>
      <a href="#weights" class="nav-link">Item True Weights</a>
      <a href="#access" class="nav-link">Access</a>
      <a href="#orders" class="nav-link">Orders</a>
      <a href="#packages" class="nav-link">Packages</a>
    </nav>
  </aside>

  <section class="content">

    <div class="page" id="page-overview">
      <header class="card hero">
        <div>
          <p class="eyebrow">Signed in as</p>
          <strong><%= admin.email %></strong>
          <p class="muted">Only approved shipping administrators can open this app.</p>
        </div>
        <div class="pill">Store: widgetco-inc.myshopify.com</div>
      </header>

      <section class="grid two">
        <article class="card">
          <p class="eyebrow">Packaging</p>
          <h2>Current defaults</h2>
          <ul>
            <li style="list-style:none; margin-left:-18px;">
              <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap; padding:4px 0;">
                <span>Package weight factor:</span>
                <span id="pkgPctDisplay"><strong>+<%= Math.round((settings.packaging.packageWeightPct - 1) * 100) %>%</strong> (factor: <%= settings.packaging.packageWeightPct %>)</span>
                <button id="pkgPctEditBtn" onclick="startPackagingEdit()" style="padding:2px 8px; border:1px solid var(--line); background:none; border-radius:6px; cursor:pointer; font-size:12px; color:var(--muted);">Edit</button>
              </div>
              <div id="pkgPctEdit" style="display:none; align-items:center; gap:6px; flex-wrap:wrap; padding:4px 0;">
                <input id="pkgPctInput" type="number" step="1" min="0" max="200" value="<%= Math.round((settings.packaging.packageWeightPct - 1) * 100) %>" style="width:72px; padding:5px 8px; border-radius:8px; border:1px solid var(--line); font:inherit;">
                <span style="color:var(--muted)">% overhead</span>
                <button onclick="savePackagingFactor()" class="button" style="padding:5px 14px; margin-top:0; font-size:13px;">Save</button>
                <button onclick="cancelPackagingEdit()" style="padding:5px 12px; border:1px solid var(--line); background:none; border-radius:8px; cursor:pointer; font-size:13px;">Cancel</button>
              </div>
            </li>
            <li>FedEx envelope enabled: <strong><%= settings.packaging.useFedexEnvelopeForExpress ? 'Yes' : 'No' %></strong></li>
            <li>Express envelope max: <strong><%= settings.packaging.expressEnvelopeMaxWeightLb %></strong> lb</li>
          </ul>
        </article>
        <article class="card">
          <p class="eyebrow">Rate engine</p>
          <h2>How weight is calculated</h2>
          <p>True unit weight &times; quantity &times; package weight factor, then services are filtered by your carrier rules.</p>
        </article>
      </section>
    </div>

    <div class="page" id="page-methods">
      <section class="card">
        <p class="eyebrow">Shipping methods</p>
        <h2>Enabled services</h2>
        <div class="carrier-groups">
        <% function mask(n){return n&&n.length>2?n.slice(0,2)+'******':n||'';} %>
          <% Object.entries(settings.carriers).filter(([c])=>c!=='ups_f').forEach(([carrier, config]) => { %>
            <div class="carrier-box">
              <div class="carrier-head">
                <h4><%= carrier.toUpperCase().replace(/_/g,'-') %></h4>
                <div class="carrier-head-right">
                  <span class="carrier-status-label"><%= config.enabled ? 'Enabled' : 'Disabled' %></span>
                  <label class="toggle carrier-toggle"><input type="checkbox" <%= config.enabled ? 'checked' : '' %> onchange="toggleCarrierSwitch('<%= carrier %>', this)" /><span class="toggle-slider"></span></label>
                </div>
              </div>
              <div class="services-columns">
                <%
                  var allSvcs = [];
                  if (carrier === 'ups') {
                    var kAcct = typeof upsAccountNumber !== 'undefined' ? mask(upsAccountNumber) : '';
                    config.services.forEach(function(s,i){ allSvcs.push({s:s,i:i,key:carrier}); });
                    if (settings.carriers.ups_f) {
                      var fAcct = typeof upsFAccountNumber !== 'undefined' ? mask(upsFAccountNumber) : '';
                      settings.carriers.ups_f.services.forEach(function(s,i){ allSvcs.push({s:s,i:i,key:'ups_f'}); });
                    }
                  } else {
                    var acct = typeof fedexAccountNumber !== 'undefined' && carrier === 'fedex' ? mask(fedexAccountNumber)
                             : typeof uspsAccountNumber !== 'undefined' && carrier === 'usps' ? mask(uspsAccountNumber)
                             : '';
                    config.services.forEach(function(s,i){ allSvcs.push({s:s,i:i,key:carrier}); });
                  }
                  var groundSvcs = allSvcs.filter(function(x){ return !x.s.air; });
                  var airSvcs   = allSvcs.filter(function(x){ return  x.s.air; });
                %>
                <div class="services-col">
                  <p class="svc-col-label">Ground / Economy</p>
                  <% groundSvcs.forEach(function(x){ %>
                    <div class="service-row">
                      <span class="service-name"><%= x.s.label %></span>
                      <label class="toggle"><input type="checkbox" <%= x.s.enabled ? 'checked' : '' %> data-carrier="<%= x.key %>" data-svc-idx="<%= x.i %>" onchange="toggleService(this)" /><span class="toggle-slider"></span></label>
                    </div>
                  <% }); %>
                  <% if (!groundSvcs.length) { %><p class="svc-col-empty">—</p><% } %>
                </div>
                <div class="services-col">
                  <p class="svc-col-label">Air / Express</p>
                  <% airSvcs.forEach(function(x){ %>
                    <div class="service-row">
                      <span class="service-name"><%= x.s.label %></span>
                      <label class="toggle"><input type="checkbox" <%= x.s.enabled ? 'checked' : '' %> data-carrier="<%= x.key %>" data-svc-idx="<%= x.i %>" onchange="toggleService(this)" /><span class="toggle-slider"></span></label>
                    </div>
                  <% }); %>
                  <% if (!airSvcs.length) { %><p class="svc-col-empty">—</p><% } %>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </section>
    </div>

    <div class="page" id="page-rules">
  <section class="card">
    <p class="eyebrow">Rules</p>
    <h2>Shipping Rules by Zone</h2>
    <p class="muted" style="margin-bottom:20px">These rules are defined in <code>src/config/shippingRules.ts</code>. Edit that file to change thresholds or labels — no other code needs to change.</p>

    <% zoneRules.forEach(function(zr) { %>
    <div style="margin-bottom:28px; border:1px solid var(--line); border-radius:12px; overflow:hidden;">
      <div style="background:var(--bg); padding:10px 16px; border-bottom:1px solid var(--line);">
        <strong style="font-size:14px"><%= zr.zone %></strong>
        <% if (zr.rules.suppressCarriers && zr.rules.suppressCarriers.length) { %>
          <span style="margin-left:10px; font-size:11px; background:#fee2e2; color:#dc2626; border-radius:20px; padding:2px 8px; font-weight:600;">USPS hidden</span>
        <% } %>
        <% if (zr.rules.suppressUspsOverSubtotal !== undefined) { %>
          <span style="margin-left:10px; font-size:11px; background:#fef9c3; color:#ca8a04; border-radius:20px; padding:2px 8px; font-weight:600;">USPS hidden over $<%= zr.rules.suppressUspsOverSubtotal %></span>
        <% } %>
      </div>
      <table style="width:100%; border-collapse:collapse; font-size:13px;">
        <thead>
          <tr style="background:var(--bg);">
            <th style="text-align:left; padding:8px 16px; font-size:11px; text-transform:uppercase; letter-spacing:.06em; color:var(--muted); border-bottom:1px solid var(--line); width:30%">Condition</th>
            <th style="text-align:left; padding:8px 16px; font-size:11px; text-transform:uppercase; letter-spacing:.06em; color:var(--muted); border-bottom:1px solid var(--line); width:35%">Label shown at checkout</th>
            <th style="text-align:left; padding:8px 16px; font-size:11px; text-transform:uppercase; letter-spacing:.06em; color:var(--muted); border-bottom:1px solid var(--line)">Price</th>
          </tr>
        </thead>
        <tbody>
          <% (zr.rules.flatTiers || []).forEach(function(tier) { %>
          <tr>
            <td style="padding:10px 16px; border-bottom:1px solid var(--line); color:var(--muted);">
              <% var parts = []; %>
              <% if (tier.minSubtotal !== undefined) parts.push('Subtotal &ge; $' + tier.minSubtotal.toFixed(2)); %>
              <% if (tier.maxSubtotal !== undefined) parts.push('Subtotal &le; $' + tier.maxSubtotal.toFixed(2)); %>
              <%- parts.length ? parts.join(' & ') : 'All orders' %>
            </td>
            <td style="padding:10px 16px; border-bottom:1px solid var(--line); font-weight:600;"><%= tier.label %></td>
            <td style="padding:10px 16px; border-bottom:1px solid var(--line);">
              <% if (tier.price === 0) { %><span style="color:#16a34a; font-weight:700;">Free</span><% } else { %>$<%= tier.price.toFixed(2) %> flat<% } %>
            </td>
          </tr>
          <% }); %>
          <% (zr.rules.calcTiers || []).forEach(function(tier) { %>
          <tr>
            <td style="padding:10px 16px; border-bottom:1px solid var(--line); color:var(--muted);">
              <% var parts = []; %>
              <% if (tier.minSubtotal !== undefined) parts.push('Subtotal &ge; $' + tier.minSubtotal.toFixed(2)); %>
              <% if (tier.maxSubtotal !== undefined) parts.push('Subtotal &le; $' + tier.maxSubtotal.toFixed(2)); %>
              <%- parts.length ? parts.join(' & ') : 'All orders' %>
            </td>
            <td style="padding:10px 16px; border-bottom:1px solid var(--line); font-weight:600;">
              <%- tier.carriers.join(' or ') %> <span style="font-weight:400; color:var(--muted);">(cheapest wins)</span>
            </td>
            <td style="padding:10px 16px; border-bottom:1px solid var(--line);">
              <% if (tier.overridePrice === 0) { %><span style="color:#16a34a; font-weight:700;">Free</span><% } else if (tier.overridePrice !== undefined) { %>$<%= tier.overridePrice.toFixed(2) %><% } else { %>Calculated<% } %>
            </td>
          </tr>
          <% }); %>
          <% if (zr.rules.passThrough && !zr.rules.flatTiers && !zr.rules.calcTiers) { %>
          <tr>
            <td style="padding:10px 16px; color:var(--muted);">All orders</td>
            <td style="padding:10px 16px; font-weight:600;">All carriers (pass-through)</td>
            <td style="padding:10px 16px;">Calculated by EasyPost</td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% }); %>

  <!-- Shipping Schedule & Holidays -->
  <section class="card" style="margin-top:24px">
    <p class="eyebrow">Shipping Schedule</p>
    <h2>Daily Cutoff &amp; Holidays</h2>
    <p class="muted" style="margin-bottom:20px">Orders must be placed before the cutoff to ship same day. Weekends and carrier-observed holidays are skipped when calculating estimated delivery dates.</p>

    <table class="rules-schedule-table" style="width:100%;border-collapse:collapse;font-size:13px;margin-bottom:28px">
      <thead>
        <tr>
          <th style="text-align:left;padding:6px 12px 6px 0;border-bottom:2px solid var(--line);color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.06em">Day</th>
          <th style="text-align:left;padding:6px 12px 6px 0;border-bottom:2px solid var(--line);color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.06em">Ships?</th>
          <th style="text-align:left;padding:6px 12px 6px 0;border-bottom:2px solid var(--line);color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.06em">Cutoff</th>
          <th style="text-align:left;padding:6px 0 6px 0;border-bottom:2px solid var(--line);color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.06em">Toggle</th>
        </tr>
      </thead>
      <tbody id="schedule-tbody"></tbody>
    </table>

    <p class="eyebrow" style="margin-top:0">Carrier Holidays</p>
    <p class="muted" style="margin-bottom:16px;font-size:13px">FedEx &amp; UPS observed holidays — no pickups on these dates.</p>
    <table class="rules-holidays-table" style="width:100%;border-collapse:collapse;font-size:13px">
      <thead>
        <tr>
          <th style="text-align:left;padding:6px 12px 6px 0;border-bottom:2px solid var(--line);color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.06em">Year</th>
          <th style="text-align:left;padding:6px 12px 6px 0;border-bottom:2px solid var(--line);color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.06em">Date</th>
          <th style="text-align:left;padding:6px 0 6px 0;border-bottom:2px solid var(--line);color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.06em">Holiday</th>
        </tr>
      </thead>
      <tbody id="holidays-tbody"></tbody>
    </table>

    <script>
    // ── Toggle CSS (injected once) ────────────────────────────────────────
    (function injectToggleStyles() {
      if (document.getElementById('toggle-css')) return;
      var style = document.createElement('style');
      style.id = 'toggle-css';
      style.textContent = [
        '.sw-wrap{display:inline-flex;align-items:center;cursor:pointer;user-select:none}',
        '.sw-track{width:36px;height:20px;border-radius:10px;background:#d1d5db;transition:background .2s;flex-shrink:0;position:relative}',
        '.sw-track.on{background:var(--accent,#111827)}',
        '.sw-thumb{position:absolute;top:2px;left:2px;width:16px;height:16px;border-radius:50%;background:#fff;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.2)}',
        '.sw-track.on .sw-thumb{transform:translateX(16px)}'
      ].join('');
      document.head.appendChild(style);
    })();

    // ── Render schedule row ───────────────────────────────────────────────
    function renderScheduleRow(i, row, sbody) {
      var existingTr = sbody.querySelector('[data-day-idx="' + i + '"]');
      var tr = existingTr || document.createElement('tr');
      tr.setAttribute('data-day-idx', i);
      tr.innerHTML =
        '<td style="padding:7px 12px 7px 0;border-bottom:1px solid var(--line);color:var(--text);font-weight:500">' + row.day + '</td>' +
        '<td style="padding:7px 12px 7px 0;border-bottom:1px solid var(--line)">' +
          (row.ships
            ? '<span style="color:var(--pill-on-text,#166534);font-weight:600">Yes</span>'
            : '<span style="color:var(--muted)">Closed</span>') +
        '</td>' +
        '<td style="padding:7px 12px 7px 0;border-bottom:1px solid var(--line);color:var(--text)">' +
          (row.cutoff || '<span style="color:var(--muted)">—</span>') +
        '</td>' +
        '<td style="padding:7px 0 7px 0;border-bottom:1px solid var(--line)">' +
          '<label class="sw-wrap" title="Toggle ' + row.day + ' shipping">' +
            '<div class="sw-track' + (row.ships ? ' on' : '') + '" id="sw-track-' + i + '">' +
              '<div class="sw-thumb"></div>' +
            '</div>' +
          '</label>' +
        '</td>';
      if (!existingTr) sbody.appendChild(tr);
      // Wire click after render
      var track = tr.querySelector('.sw-track');
      if (track) {
        track.onclick = function() { window.toggleShipDay(i); };
      }
    }

    // ── Toggle a shipping day on/off ──────────────────────────────────────
    window.toggleShipDay = function(i) {
      SHIP_SCHEDULE[i].ships = !SHIP_SCHEDULE[i].ships;
      // Re-render the row
      var sbody = document.getElementById('schedule-tbody');
      if (sbody) renderScheduleRow(i, SHIP_SCHEDULE[i], sbody);
      // Sync the estimator's bizHolidays reference (no page reload needed)
      // The estimator re-computes bizHolidays fresh on each "Get Rates" click,
      // so no action needed here — SHIP_SCHEDULE is already updated in memory.
    };

    // ── Build schedule table on load ─────────────────────────────────────
    (function() {
      var sbody = document.getElementById('schedule-tbody');
      if (sbody) {
        SHIP_SCHEDULE.forEach(function(row, i) {
          renderScheduleRow(i, row, sbody);
        });
      }

      // ── Build holidays table ──────────────────────────────────────────
      var hbody = document.getElementById('holidays-tbody');
      if (hbody) {
        var yearLabels = [2026,2026,2026,2026,2026,2026,2026,2027,2027,2027,2027,2027,2027,2027];
        BIZ_HOLIDAYS.forEach(function(h, i) {
          var year = yearLabels[i] || '';
          var parts = h.date.split('/');
          var month = parseInt(parts[0], 10);
          var day = parseInt(parts[1], 10);
          var dateObj = new Date(year, month - 1, day);
          var formatted = dateObj.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
          var tr = document.createElement('tr');
          tr.innerHTML =
            '<td style="padding:7px 12px 7px 0;border-bottom:1px solid var(--line);color:var(--muted)">' + year + '</td>' +
            '<td style="padding:7px 12px 7px 0;border-bottom:1px solid var(--line);color:var(--text)">' + formatted + '</td>' +
            '<td style="padding:7px 0 7px 0;border-bottom:1px solid var(--line);color:var(--text)">' + h.label + '</td>';
          hbody.appendChild(tr);
        });
      }
    })();
    </script>
  </section>
  </section>
</div>
