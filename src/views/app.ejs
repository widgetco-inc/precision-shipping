<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>WidgetCo Precision Shipping</title>
  <link rel="stylesheet" href="/styles.css" />
  <style>
    .est-section { margin-top: 20px; }
    .est-section-label { font-size: 11px; text-transform: uppercase; letter-spacing: .08em; color: var(--muted); margin: 0 0 12px; font-weight: 700; }
    .est-sku-header { display: grid; grid-template-columns: 1fr 80px 130px 110px 32px; gap: 8px; padding: 4px 0 6px; font-size: 11px; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); border-bottom: 1px solid var(--line); }
    .est-row { display: grid; grid-template-columns: 1fr 80px 130px 110px 32px; gap: 8px; align-items: center; padding: 8px 0; border-bottom: 1px solid var(--line); }
    .est-row:last-child { border-bottom: none; }
    .est-sku-wrap { position: relative; }
    .est-sku-input, .est-qty-input, .est-manual-weight { width: 100%; border: 1.5px solid #d1d5db; border-radius: 8px; padding: 11px 12px; font: inherit; font-size: 14px; box-sizing: border-box; background: #fff; }
    .est-sku-input:focus, .est-qty-input:focus, .est-manual-weight:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(17,24,39,.08); }
    .est-qty-input { text-align: center; }
    .est-unit-g { font-size: 12px; color: var(--muted); }
    .est-unit-g.found { color: var(--pill-on-text); font-weight: 600; }
    .est-row-total { font-size: 13px; font-weight: 600; color: var(--text); }
    .est-remove-btn { background: none; border: none; cursor: pointer; color: var(--muted); font-size: 16px; padding: 2px 6px; border-radius: 4px; transition: color .15s; line-height: 1; }
    .est-remove-btn:hover { color: #dc2626; }
    .est-add-btn { margin-top: 10px; background: rgba(17,24,39,.04); border: 1px dashed var(--line); border-radius: 8px; color: var(--muted); font: inherit; font-size: 13px; cursor: pointer; padding: 8px 16px; width: 100%; transition: background .15s; }
    .est-add-btn:hover { background: rgba(17,24,39,.08); color: var(--text); }
    .est-ac { position: absolute; top: 100%; left: 0; right: 0; background: #fff; border: 1px solid var(--line); border-radius: 8px; z-index: 100; max-height: 180px; overflow-y: auto; margin-top: 2px; box-shadow: 0 8px 24px rgba(17,24,39,.12); display: none; }
    .est-ac-item { padding: 8px 12px; font-size: 13px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
    .est-ac-item:hover { background: var(--bg); }
    .est-ac-wt { font-size: 11px; color: var(--pill-on-text); font-weight: 600; }
    .est-totals { display: flex; flex-wrap: wrap; gap: 20px; background: var(--bg); border: 1px solid var(--line); border-radius: 12px; padding: 12px 16px; margin-top: 16px; margin-bottom: 4px; font-size: 13px; color: var(--muted); }
    .est-total-item strong { color: var(--text); margin-left: 4px; }
    .est-label { display: grid; gap: 6px; }
    .est-label-text { font-size: 13px; color: var(--text); font-weight: 600; }
    .est-label input { width: 100%; border: 1.5px solid #d1d5db; border-radius: 8px; padding: 12px 14px; font: inherit; font-size: 14px; box-sizing: border-box; background: #fff; color: var(--text); transition: border-color .15s, box-shadow .15s; }
    .est-label input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(17,24,39,.1); }
    .est-label input::placeholder { color: #9ca3af; }
    .acct-label { font-size: 11px; font-weight: 600; color: var(--muted); margin: 6px 0 2px; letter-spacing: .04em; }
    /* ── Weights table ─────────────────────────────────────────────────────────── */
    .weights-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 4px; }
    .weights-table th { text-align: left; padding: 8px 12px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); background: var(--bg); border-bottom: 2px solid var(--line); white-space: nowrap; }
    .weights-table td { padding: 7px 12px; border-bottom: 1px solid var(--line); vertical-align: middle; }
    .weights-table tbody tr:last-child td { border-bottom: none; }
    .weights-table tbody tr:hover { background: var(--bg); }
    .weights-table td:last-child, .weights-table th:last-child { text-align: center; }
    .sku-search-row input { font-size: 13px; padding: 7px 12px; width: 260px; border-radius: 10px; }
  </style>
</head>
<body>
<main class="shell">
  <aside class="sidebar">
    <div>
      <strong>Precision Shipping</strong>
      <p class="muted">WidgetCo custom shipping app</p>
    </div>
    <nav id="pageNav">
      <a href="#overview" class="nav-link">Overview</a>
      <a href="#methods" class="nav-link">Shipping methods</a>
      <a href="#rules" class="nav-link">Rules</a>
      <a href="#preview" class="nav-link">Estimator</a>
      <a href="#weights" class="nav-link">Item True Weights</a>
      <a href="#access" class="nav-link">Access</a>
    </nav>
  </aside>

  <section class="content">

    <div class="page" id="page-overview">
      <header class="card hero">
        <div>
          <p class="eyebrow">Signed in as</p>
          <strong><%= admin.email %></strong>
          <p class="muted">Only approved shipping administrators can open this app.</p>
        </div>
        <div class="pill">Store: widgetco-inc.myshopify.com</div>
      </header>

      <section class="grid two">
        <article class="card">
          <p class="eyebrow">Packaging</p>
          <h2>Current defaults</h2>
          <ul>
            <li style="list-style:none; margin-left:-18px;">
              <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap; padding:4px 0;">
                <span>Package weight factor:</span>
                <span id="pkgPctDisplay"><strong>+<%= Math.round((settings.packaging.packageWeightPct - 1) * 100) %>%</strong> (factor: <%= settings.packaging.packageWeightPct %>)</span>
                <button id="pkgPctEditBtn" onclick="startPackagingEdit()" style="padding:2px 8px; border:1px solid var(--line); background:none; border-radius:6px; cursor:pointer; font-size:12px; color:var(--muted);">Edit</button>
              </div>
              <div id="pkgPctEdit" style="display:none; align-items:center; gap:6px; flex-wrap:wrap; padding:4px 0;">
                <input id="pkgPctInput" type="number" step="1" min="0" max="200" value="<%= Math.round((settings.packaging.packageWeightPct - 1) * 100) %>" style="width:72px; padding:5px 8px; border-radius:8px; border:1px solid var(--line); font:inherit;">
                <span style="color:var(--muted)">% overhead</span>
                <button onclick="savePackagingFactor()" class="button" style="padding:5px 14px; margin-top:0; font-size:13px;">Save</button>
                <button onclick="cancelPackagingEdit()" style="padding:5px 12px; border:1px solid var(--line); background:none; border-radius:8px; cursor:pointer; font-size:13px;">Cancel</button>
              </div>
            </li>
            <li>FedEx envelope enabled: <strong><%= settings.packaging.useFedexEnvelopeForExpress ? 'Yes' : 'No' %></strong></li>
            <li>Express envelope max: <strong><%= settings.packaging.expressEnvelopeMaxWeightLb %></strong> lb</li>
          </ul>
        </article>
        <article class="card">
          <p class="eyebrow">Rate engine</p>
          <h2>How weight is calculated</h2>
          <p>True unit weight &times; quantity &times; package weight factor, then services are filtered by your carrier rules.</p>
        </article>
      </section>
    </div>

    <div class="page" id="page-methods">
      <section class="card">
        <p class="eyebrow">Shipping methods</p>
        <h2>Enabled services</h2>
        <div class="carrier-groups">
        <% function mask(n){return n&&n.length>2?n.slice(0,2)+'******':n||'';} %>
          <% Object.entries(settings.carriers).filter(([c])=>c!=='ups_f').forEach(([carrier, config]) => { %>
            <div class="carrier-box">
              <div class="carrier-head">
                <h4><%= carrier.toUpperCase().replace('_','-') %></h4>
                <span class="pill <%= config.enabled ? 'on' : 'off' %>"><%= config.enabled ? 'Enabled' : 'Disabled' %></span>
              </div>
              <div>
                <% if (carrier === 'ups') { %>
                  <% var kAcct = typeof upsAccountNumber !== 'undefined' ? mask(upsAccountNumber) : ''; %>
                  <% if (kAcct) { %><p class="acct-label"><%= kAcct %></p><% } %>
                  <% config.services.forEach(function(service){ %>
                    <div class="service-row"><span class="service-name"><%= service.label %></span>
                    <label class="toggle"><input type="checkbox" <%= service.enabled ? 'checked' : '' %> disabled /><span class="slider"></span></label></div>
                  <% }); %>
                  <% if (settings.carriers.ups_f) { %>
                    <% var fAcct = typeof upsFAccountNumber !== 'undefined' ? mask(upsFAccountNumber) : ''; %>
                    <% if (fAcct) { %><p class="acct-label"><%= fAcct %></p><% } %>
                    <% settings.carriers.ups_f.services.forEach(function(service){ %>
                      <div class="service-row"><span class="service-name"><%= service.label %></span>
                      <label class="toggle"><input type="checkbox" <%= service.enabled ? 'checked' : '' %> disabled /><span class="slider"></span></label></div>
                    <% }); %>
                  <% } %>
                <% } else { %>
                  <% var acctMap = {fedex: fedexAccountNumber, usps: uspsAccountNumber}; %>
                  <% var acct = typeof acctMap[carrier] !== 'undefined' ? mask(acctMap[carrier]) : ''; %>
                  <% if (acct) { %><p class="acct-label"><%= acct %></p><% } %>
                  <% config.services.forEach(function(service){ %>
                    <div class="service-row"><span class="service-name"><%= service.label %></span>
                    <label class="toggle"><input type="checkbox" <%= service.enabled ? 'checked' : '' %> disabled /><span class="slider"></span></label></div>
                  <% }); %>
                <% } %>
              </div>
            </div>
          <% }); %>
        </div>
      </section>
    </div>

    <div class="page" id="page-rules">
      <section class="card">
        <p class="eyebrow">Rules</p>
        <h2>Business logic summary</h2>
        <ul>
          <li>Use true micro-weight, never rounded catalog weight, for shipment math.</li>
          <li>USPS Ground Advantage stays under 1 lb.</li>
          <li>USPS International Mail stays under 4 lb.</li>
          <li>FedEx express services can use envelope logic under <%= settings.packaging.expressEnvelopeMaxWeightLb %> lb when eligible.</li>
          <li>Everything else falls back to the enabled parcel services for the destination.</li>
        </ul>
      </section>
    </div>

    <div class="page" id="page-preview">
      <section class="card estimator-card">
        <p class="eyebrow">Estimator</p>
        <h2>Rate Estimator</h2>

        <div class="est-section">
          <div class="grid three">
            <label class="est-label">
              <span class="est-label-text">From ZIP</span>
              <input id="estFromZip" type="text" placeholder="ZIP code" maxlength="10" />
            </label>
            <label class="est-label">
              <span class="est-label-text">To ZIP / Postal code</span>
              <input id="estToZip" type="text" placeholder="ZIP / Postal code" />
            </label>
            <label class="est-label">
              <span class="est-label-text">To Country</span>
              <input id="estCountry" type="text" placeholder="Country" value="US" maxlength="3" />
            </label>
          </div>
        </div>

        <div class="est-section">
          <p class="est-section-label">Box size <span class="muted">(optional — inches)</span></p>
          <div class="grid three">
            <label class="est-label">
              <span class="est-label-text">Length</span>
              <input id="estBoxL" type="number" step="0.1" min="0" placeholder="Length" />
            </label>
            <label class="est-label">
              <span class="est-label-text">Width</span>
              <input id="estBoxW" type="number" step="0.1" min="0" placeholder="Width" />
            </label>
            <label class="est-label">
              <span class="est-label-text">Height</span>
              <input id="estBoxH" type="number" step="0.1" min="0" placeholder="Height" />
            </label>
          </div>
        </div>

        <div class="est-section">
          <p class="est-section-label">Items</p>
          <div class="est-sku-header">
            <span>SKU</span><span>Qty</span><span>g / unit</span><span>Total g</span><span></span>
          </div>
          <div id="estSkuRows"></div>
          <button class="est-add-btn" id="estAddRow" type="button">+ Add SKU</button>
        </div>

        <div class="est-totals">
          <div class="est-total-item">Total items: <strong id="estTotalQty">0</strong></div>
          <div class="est-total-item">Total weight: <strong id="estTotalG">0 g</strong></div>
          <div class="est-total-item">= <strong id="estTotalLb">0 lb</strong></div>
          <div class="est-total-item" id="estBoxDimDisplay" style="display:none">Box: <strong id="estBoxDimText"></strong></div>
        </div>

        <button class="button" id="estRunBtn" type="button">Get Rates</button>

        <div id="estResults" style="display:none">
          <p class="est-section-label" style="margin-top:20px">Preview Results</p>
          <pre id="estOut" class="output"></pre>
        </div>
      </section>
    </div>

    <div class="page" id="page-weights">
      <section class="card">
        <details open>
        <summary><p class="eyebrow">Weights</p><h2>Variant true-weight sync</h2></summary>
        <p class="muted">Scan every Shopify product variant and flag any whose <code>custom.actual_weight_grams</code> metafield is missing or differs &gt;20% from the Shopify catalog weight.</p>

        <!-- Nightly alert banner -->
        <div id="nightlyAlertBanner" style="display:none" class="alert-banner"></div>

        <!-- CSV import -->
        <details class="csv-import-details">
          <summary>Import weights from CSV</summary>
          <div class="csv-import-body">
            <p class="muted">Upload a CSV exported from Shopify (Matrixify format with <code>ID</code>, <code>Variant SKU</code>, and <code>Metafield: custom.actual_weight_grams</code> columns is supported), or use a simple two-column <code>sku,grams</code> format. Each row sets the <code>actual_weight_grams</code> metafield for that SKU.</p>
            <div class="csv-upload-row">
              <input type="file" id="csvFileInput" accept=".csv,text/csv,text/plain" />
              <button class="button" id="csvUploadBtn" type="button">Upload &amp; Import</button>
            </div>
            <pre id="csvResult" class="output" style="display:none"></pre>
          </div>
        </details>

        <!-- Sync toolbar -->
        <div class="weights-toolbar">
          <button class="button" id="syncWeightsBtn" type="button">Run sync</button>
          <span id="syncStatus" class="muted"></span>
        </div>

        <!-- SKU search -->
        <div class="sku-search-row">
          <input type="text" id="skuSearch" placeholder="Search SKU or product…" />
        </div>

        <div id="syncWarnings"></div>

        <table id="weightsTable" class="weights-table" style="display:none">
          <thead>
            <tr>
              <th>Product</th>
              <th>Variant</th>
              <th>SKU</th>
              <th>Shopify (g)</th>
              <th>True weight (g)</th>
              <th>Status</th>
              <th>Edit</th>
            </tr>
          </thead>
          <tbody id="weightsTableBody"></tbody>
        </table>
        </details>
      </section>

      <section class="card" id="uploadedWeightsCard" style="margin-top:16px">
        <p class="eyebrow">Uploaded CSV Weights</p>
        <h2>SKU weight comparison</h2>
        <p class="muted">All SKUs imported from CSV, compared against the Shopify <code>custom.actual_weight_grams</code> metafield. A <span style="color:#16a34a">&#10003;</span> means values match; a <span style="color:#dc2626">&#10007;</span> means they differ or the metafield is missing.</p>
        <div class="sku-search-row" style="margin-bottom:12px">
          <input type="text" id="uploadedSkuSearch" placeholder="Filter by SKU…" />
        </div>
        <p id="uploadedWeightsEmpty" class="muted" style="display:none">No uploaded weights yet. Use CSV import above to add weights.</p>
        <table id="uploadedWeightsTable" class="weights-table" style="display:none">
          <thead>
            <tr>
              <th>SKU</th>
              <th>Uploaded Weight (g)</th>
              <th>Shopify Weight (g)</th>
              <th>Status</th>
              <th>Remove</th>
            </tr>
          </thead>
          <tbody id="uploadedWeightsTableBody"></tbody>
        </table>
      </section>
    </div>

    <div class="page" id="page-access">
      <section class="card">
        <p class="eyebrow">Access</p>
        <h2>Approved admins</h2>
        <ul>
          <% settings.access.allowedAdminEmails.forEach(email => { %>
            <li><%= email %></li>
          <% }) %>
        </ul>
      </section>
    </div>

  </section>
</main>

<script>
// ── Nightly alert banner ──────────────────────────────────────────────────────
async function loadNightlyAlerts() {
  const res = await fetch('/api/weights/alerts');
  if (!res.ok) return;
  const { alert } = await res.json();
  const banner = document.getElementById('nightlyAlertBanner');
  if (!alert) return;
  if (alert.warnings.length === 0) {
    banner.style.display = 'none';
    return;
  }
  const ranAt = new Date(alert.ranAt).toLocaleString();
  banner.style.display = 'block';
  banner.innerHTML =
    '<strong>⚠ Nightly weight check (' + ranAt + '): ' + alert.warnings.length + ' issue(s) found</strong>' +
    '<ul>' +
    alert.warnings.map(w =>
      '<li class="warning-' + w.status + '"><strong>' + escHtml(w.productTitle) + ' — ' + escHtml(w.variantTitle) + '</strong>' +
      ' (' + escHtml(w.sku) + '): ' + escHtml(w.message) + '</li>'
    ).join('') +
    '</ul>';
}

// ── Weights sync ──────────────────────────────────────────────────────────────
async function loadSyncStatus() {
  const res = await fetch('/api/weights/sync-status');
  if (!res.ok) return;
  const data = await res.json();
  renderWeightsResult(data.result);
  if (data.inProgress) {
    document.getElementById('syncStatus').textContent = 'Sync in progress…';
    setTimeout(loadSyncStatus, 2000);
  }
}

function escHtml(str) {
  return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function renderWeightsResult(result) {
  if (!result) return;
  const warnings = result.warnings ?? [];
  const records  = result.records  ?? [];
  const statusEl = document.getElementById('syncStatus');
  statusEl.textContent = 'Last sync: ' + records.length + ' variants scanned, ' + warnings.length + ' warning(s)';

  const warnDiv = document.getElementById('syncWarnings');
  if (warnings.length) {
    warnDiv.innerHTML =
      '<ul class="warnings">' +
      warnings.map(w =>
        '<li class="warning-' + w.status + '"><strong>' + escHtml(w.productTitle) + ' — ' + escHtml(w.variantTitle) + '</strong>' +
        ' (' + escHtml(w.sku) + '): ' +
        (w.status === 'missing' ? 'true weight metafield not set' : escHtml(w.metafieldGrams) + 'g vs catalog ' + escHtml(w.shopifyCatalogGrams) + 'g') +
        '</li>'
      ).join('') +
      '</ul>';
  } else {
    warnDiv.innerHTML = '';
  }

  if (records.length) {
    const tbody = document.getElementById('weightsTableBody');
    tbody.innerHTML = records.map(r =>
      '<tr data-variant-id="' + r.variantId + '" class="status-' + r.status + '">' +
      '<td>' + escHtml(r.productTitle) + '</td>' +
      '<td>' + escHtml(r.variantTitle) + '</td>' +
      '<td>' + escHtml(r.sku) + '</td>' +
      '<td>' + r.shopifyCatalogGrams + '</td>' +
      '<td class="weight-cell">' +
        '<span class="weight-display">' + (r.metafieldGrams !== null ? r.metafieldGrams : '—') + '</span>' +
        '<input class="weight-input" type="number" step="0.0001" min="0.0001" value="' + (r.metafieldGrams ?? '') + '" style="display:none" />' +
      '</td>' +
      '<td><span class="pill ' + (r.status === 'ok' ? 'on' : 'off') + '">' + r.status.toUpperCase() + '</span></td>' +
      '<td>' +
        '<button class="btn-edit" type="button" onclick="startEditWeight(this)">Edit</button>' +
        '<button class="btn-save" type="button" onclick="saveWeight(this)" style="display:none">Save</button>' +
      '</td>' +
      '</tr>'
    ).join('');
    document.getElementById('weightsTable').style.display = '';
    applySkuFilter();
  }
}

function startEditWeight(btn) {
  const row = btn.closest('tr');
  row.querySelector('.weight-display').style.display = 'none';
  row.querySelector('.weight-input').style.display = '';
  row.querySelector('.btn-edit').style.display = 'none';
  row.querySelector('.btn-save').style.display = '';
}

async function saveWeight(btn) {
  const row = btn.closest('tr');
  const variantId = row.dataset.variantId;
  const input = row.querySelector('.weight-input');
  const grams = parseFloat(input.value);
  if (!grams || grams <= 0) { alert('Enter a valid weight in grams.'); return; }
  const res = await fetch('/api/weights/' + variantId, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ grams }),
  });
  if (!res.ok) { alert('Save failed.'); return; }
  row.querySelector('.weight-display').textContent = grams;
  row.querySelector('.weight-display').style.display = '';
  input.style.display = 'none';
  row.querySelector('.btn-edit').style.display = '';
  btn.style.display = 'none';
}

document.getElementById('syncWeightsBtn').addEventListener('click', async () => {
  const statusEl = document.getElementById('syncStatus');
  statusEl.textContent = 'Starting sync…';
  document.getElementById('syncWeightsBtn').disabled = true;
  const res = await fetch('/api/weights/sync', { method: 'POST' });
  if (!res.ok) { statusEl.textContent = 'Sync failed.'; document.getElementById('syncWeightsBtn').disabled = false; return; }
  statusEl.textContent = 'Sync running…';
  setTimeout(() => {
    document.getElementById('syncWeightsBtn').disabled = false;
    loadSyncStatus();
  }, 1500);
});

// ── SKU search / filter ───────────────────────────────────────────────────────
function applySkuFilter() {
  const q = document.getElementById('skuSearch').value.toLowerCase().trim();
  const rows = document.querySelectorAll('#weightsTableBody tr');
  rows.forEach(row => {
    if (!q) { row.style.display = ''; return; }
    const text = row.textContent.toLowerCase();
    row.style.display = text.includes(q) ? '' : 'none';
  });
}

document.getElementById('skuSearch').addEventListener('input', applySkuFilter);

// ── CSV import ────────────────────────────────────────────────────────────────
document.getElementById('csvUploadBtn').addEventListener('click', async () => {
  const fileInput = document.getElementById('csvFileInput');
  const resultPre = document.getElementById('csvResult');
  if (!fileInput.files || fileInput.files.length === 0) {
    alert('Please select a CSV file first.');
    return;
  }
  const file = fileInput.files[0];
  const csvText = await file.text();
  const btn = document.getElementById('csvUploadBtn');
  btn.disabled = true;
  btn.textContent = 'Importing…';
  resultPre.style.display = '';
  resultPre.textContent = 'Sending…';
  try {
    const res = await fetch('/api/weights/csv', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ csv: csvText }),
    });
    const data = await res.json();
    if (data.error) {
      resultPre.textContent = 'Error: ' + data.error;
    } else {
      resultPre.textContent =
        'Done: ' + data.succeeded + '/' + data.attempted + ' rows imported.' +
        (data.skipped > 0 ? ' ' + data.skipped + ' skipped.' : '') +
        (data.errors && data.errors.length > 0
          ? '\n\nIssues:\n' + data.errors.map(e => '  ' + e.sku + ': ' + e.reason).join('\n')
          : '');
      // Refresh the tables
      loadSyncStatus();
      loadUploadedWeightsTable();
    }
  } catch (err) {
    resultPre.textContent = 'Upload failed: ' + err.message;
  } finally {
    btn.disabled = false;
    btn.textContent = 'Upload & Import';
  }
});

// ── Uploaded weights table ───────────────────────────────────────────────────
async function loadUploadedWeightsTable() {
  const [uploadedRes, syncRes] = await Promise.allSettled([
    fetch('/api/weights/uploaded'),
    fetch('/api/weights/sync-status'),
  ]);

  let uploadedMap = {};
  if (uploadedRes.status === 'fulfilled' && uploadedRes.value.ok) {
    const d = await uploadedRes.value.json();
    if (Array.isArray(d)) {
      d.forEach(item => { uploadedMap[item.sku] = item.grams; });
    } else {
      uploadedMap = d;
    }
  }

  let metafieldMap = {};
  if (syncRes.status === 'fulfilled' && syncRes.value.ok) {
    const d = await syncRes.value.json();
    const records = (d.result && d.result.records) ? d.result.records : [];
    records.forEach(r => {
      if (r.sku) metafieldMap[r.sku] = r.metafieldGrams;
    });
  }

  const skus = Object.keys(uploadedMap);
  const empty = document.getElementById('uploadedWeightsEmpty');
  const table = document.getElementById('uploadedWeightsTable');
  const tbody = document.getElementById('uploadedWeightsTableBody');

  if (!skus.length) {
    empty.style.display = '';
    table.style.display = 'none';
    return;
  }

  empty.style.display = 'none';
  const rows = skus.sort().map(sku => {
    const uploaded = uploadedMap[sku];
    const shopify  = metafieldMap.hasOwnProperty(sku) ? metafieldMap[sku] : null;
    const match    = shopify !== null && Math.abs(uploaded - shopify) < 0.5;
    const statusHtml = shopify === null
      ? '<span title="No Shopify metafield found for this SKU" style="color:#f59e0b;font-size:16px">&#9900;</span>'
      : match
        ? '<span title="Weights match" style="color:#16a34a;font-size:16px">&#10003;</span>'
        : '<span title="Mismatch" style="color:#dc2626;font-size:16px">&#10007;</span>';
    return '<tr data-sku="' + escHtml(sku) + '">' +
      '<td><code>' + escHtml(sku) + '</code></td>' +
      '<td>' + uploaded + ' g</td>' +
      '<td>' + (shopify !== null ? shopify + ' g' : '<span class=\"muted\">\u2014</span>') + '</td>' +
      '<td style="font-size:18px;text-align:center">' + statusHtml + '</td>' +
      '<td style="text-align:center"><button class="btn-remove-sku" type="button" data-sku="' + escHtml(sku) + '" title="Remove discontinued SKU" style="background:none;border:none;cursor:pointer;color:var(--muted);font-size:14px;padding:3px 7px;border-radius:6px;line-height:1">&#10007;</button></td>' +
      '</tr>';
  });

  tbody.innerHTML = rows.join('');
  table.style.display = '';
  applyUploadedSkuFilter();
}

function applyUploadedSkuFilter() {
  const q = (document.getElementById('uploadedSkuSearch')?.value || '').toLowerCase().trim();
  const rows = document.querySelectorAll('#uploadedWeightsTableBody tr');
  rows.forEach(row => {
    if (!q) { row.style.display = ''; return; }
    row.style.display = row.dataset.sku?.toLowerCase().includes(q) ? '' : 'none';
  });
}

document.getElementById('uploadedSkuSearch')?.addEventListener('input', applyUploadedSkuFilter);

document.getElementById('uploadedWeightsTableBody')?.addEventListener('click', async (e) => {
  const btn = e.target.closest('.btn-remove-sku');
  if (!btn) return;
  const sku = btn.dataset.sku;
  if (!sku || !confirm('Remove "' + sku + '" from the uploaded weights list?')) return;
  btn.disabled = true;
  const res = await fetch('/api/weights/uploaded/' + encodeURIComponent(sku), { method: 'DELETE' });
  if (!res.ok) { alert('Failed to remove SKU.'); btn.disabled = false; return; }
  btn.closest('tr').remove();
  if (!document.querySelector('#uploadedWeightsTableBody tr')) {
    document.getElementById('uploadedWeightsTable').style.display = 'none';
    document.getElementById('uploadedWeightsEmpty').style.display = '';
  }
});

// ── Init ──────────────────────────────────────────────────────────────────────
loadSyncStatus();
loadNightlyAlerts();
loadUploadedWeightsTable();
</script>

<script>
// ── Rate Estimator ──────────────────────────────────────────────────────────
(async function initEstimator() {
  const skuWeights = {}, skuList = [];
  try {
    const data = await fetch('/api/weights/uploaded').then(r => r.json());
    Object.entries(data).forEach(([sku, wg]) => {
      if (sku && typeof wg === 'number') { skuWeights[sku.toUpperCase()] = wg; skuList.push(sku); }
    });
  } catch (_) {}

  function esc(s) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  function getRows() { return Array.from(document.querySelectorAll('#estSkuRows .est-row')); }

  function updateTotals() {
    let totalQty = 0, totalG = 0;
    getRows().forEach(row => {
      const skuVal = row.querySelector('.est-sku-input').value.toUpperCase().trim();
      const qty    = parseInt(row.querySelector('.est-qty-input').value) || 0;
      let unitG    = skuWeights[skuVal];
      if (unitG === undefined) unitG = parseFloat(row.querySelector('.est-manual-weight').value) || 0;
      const rowG   = unitG * qty;
      row.querySelector('.est-row-total').textContent = (qty > 0 && unitG > 0) ? rowG.toFixed(2) + ' g' : '—';
      if (qty > 0 && unitG > 0) { totalQty += qty; totalG += rowG; }
    });
    document.getElementById('estTotalQty').textContent = totalQty.toLocaleString();
    document.getElementById('estTotalG').textContent   = totalG.toFixed(2) + ' g';
    document.getElementById('estTotalLb').textContent  = (totalG / 453.59237).toFixed(4) + ' lb';
    const L = parseFloat(document.getElementById('estBoxL').value) || 0;
    const W = parseFloat(document.getElementById('estBoxW').value) || 0;
    const H = parseFloat(document.getElementById('estBoxH').value) || 0;
    const boxEl = document.getElementById('estBoxDimDisplay');
    if (L > 0 && W > 0 && H > 0) {
      document.getElementById('estBoxDimText').textContent = L + '×' + W + '×' + H + ' in';
      boxEl.style.display = '';
    } else { boxEl.style.display = 'none'; }
  }

  function showAC(inp, dd) {
    const val = inp.value.toUpperCase().trim();
    dd.innerHTML = '';
    if (!val) { dd.style.display = 'none'; return; }
    const matches = skuList.filter(s => s.toUpperCase().includes(val)).slice(0, 20);
    if (!matches.length) { dd.style.display = 'none'; return; }
    matches.forEach(sku => {
      const item = document.createElement('div');
      item.className = 'est-ac-item';
      const w = skuWeights[sku.toUpperCase()];
      item.innerHTML = '<span>' + esc(sku) + '</span><span class="est-ac-wt">' + (w !== undefined ? w + ' g' : '') + '</span>';
      item.addEventListener('mousedown', e => {
        e.preventDefault();
        inp.value = sku; dd.style.display = 'none';
        const row = inp.closest('.est-row');
        const unit = row.querySelector('.est-unit-g');
        const manual = row.querySelector('.est-manual-weight');
        if (w !== undefined) { unit.textContent = w + ' g'; unit.className = 'est-unit-g found'; manual.style.display = 'none'; }
        else { unit.textContent = 'Not found — enter g:'; unit.className = 'est-unit-g'; manual.style.display = ''; }
        updateTotals();
        row.querySelector('.est-qty-input').focus();
      });
      dd.appendChild(item);
    });
    dd.style.display = 'block';
  }

  let rowCount = 0;
  function addRow(skuVal, qtyVal) {
    skuVal = skuVal || ''; qtyVal = qtyVal || 1;
    const id  = ++rowCount;
    const sku = skuVal.toUpperCase().trim();
    const w   = skuWeights[sku];
    const found = typeof w === 'number';
    const row = document.createElement('div');
    row.className = 'est-row'; row.setAttribute('data-row', id);
    row.innerHTML =
      '<div class="est-sku-wrap">' +
        '<input type="text" class="est-sku-input" placeholder="SKU" value="' + esc(skuVal) + '" autocomplete="off" />' +
        '<div class="est-ac"></div>' +
      '</div>' +
      '<input type="number" class="est-qty-input" value="' + qtyVal + '" min="1" step="1" />' +
      '<span class="est-unit-g' + (found ? ' found' : '') + '">' + (found ? w + ' g' : (skuVal ? 'Not found — enter g:' : '—')) + '</span>' +
      '<input type="number" class="est-manual-weight" step="0.0001" min="0.0001" placeholder="g" style="display:' + (!found && skuVal ? '' : 'none') + '" />' +
      '<span class="est-row-total">—</span>' +
      '<button class="est-remove-btn" type="button">✕</button>';
    document.getElementById('estSkuRows').appendChild(row);
    const inp = row.querySelector('.est-sku-input');
    const dd  = row.querySelector('.est-ac');
    const unit = row.querySelector('.est-unit-g');
    const manual = row.querySelector('.est-manual-weight');
    inp.addEventListener('input', () => {
      showAC(inp, dd);
      const s = inp.value.toUpperCase().trim(), wt = skuWeights[s];
      if (!s)      { unit.textContent = '—'; unit.className = 'est-unit-g'; manual.style.display = 'none'; }
      else if (wt !== undefined) { unit.textContent = wt + ' g'; unit.className = 'est-unit-g found'; manual.style.display = 'none'; }
      else         { unit.textContent = 'Not found — enter g:'; unit.className = 'est-unit-g'; manual.style.display = ''; }
      updateTotals();
    });
    inp.addEventListener('focus', () => showAC(inp, dd));
    inp.addEventListener('blur',  () => setTimeout(() => { dd.style.display = 'none'; }, 150));
    inp.addEventListener('keydown', e => { if (e.key === 'Tab' || e.key === 'Enter') dd.style.display = 'none'; });
    row.querySelector('.est-qty-input').addEventListener('input', updateTotals);
    manual.addEventListener('input', updateTotals);
    row.querySelector('.est-remove-btn').addEventListener('click', () => { row.remove(); updateTotals(); });
    updateTotals();
    if (!skuVal) inp.focus();
  }

  ['estBoxL','estBoxW','estBoxH'].forEach(id => document.getElementById(id).addEventListener('input', updateTotals));

  addRow();
  document.getElementById('estAddRow').addEventListener('click', () => addRow());

  document.getElementById('estRunBtn').addEventListener('click', async () => {
    const btn  = document.getElementById('estRunBtn');
    const reEl = document.getElementById('estResults');
    const out  = document.getElementById('estOut');
    const cc   = (document.getElementById('estCountry').value.trim() || 'US').toUpperCase();
    const zip  = document.getElementById('estToZip').value.trim();
    const lines = [];
    getRows().forEach(row => {
      const s   = row.querySelector('.est-sku-input').value.toUpperCase().trim();
      const qty = parseInt(row.querySelector('.est-qty-input').value) || 0;
      let wg    = skuWeights[s];
      if (wg === undefined) wg = parseFloat(row.querySelector('.est-manual-weight').value) || 0;
      if (qty > 0 && wg > 0) lines.push({ sku: s || undefined, quantity: qty, trueWeightGrams: wg });
    });
    if (!lines.length) { reEl.style.display = ''; out.textContent = 'Add at least one SKU with a valid weight.'; return; }
    btn.disabled = true; btn.textContent = 'Getting rates…';
    reEl.style.display = ''; out.textContent = 'Calculating…';
    try {
      const data = await fetch('/api/preview', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ destination: { countryCode: cc, postalCode: zip }, lines })
      }).then(r => r.json());
      let txt = '';
      if (data.shipment) {
        const s = data.shipment;
        const fromZip = document.getElementById('estFromZip').value.trim();
        const L = parseFloat(document.getElementById('estBoxL').value) || 0;
        const W = parseFloat(document.getElementById('estBoxW').value) || 0;
        const H = parseFloat(document.getElementById('estBoxH').value) || 0;
        txt += '── Shipment Summary ────────────────────────────────────────────────';
        if (fromZip) txt += '  From:           ' + fromZip + '';
        txt += '  To:             ' + (zip || '(no zip)') + ', ' + cc + '';
        if (L > 0 && W > 0 && H > 0) txt += '  Box:            ' + L + ' × ' + W + ' × ' + H + ' in';
        txt += '  Lines:          ' + lines.length + '';
        txt += '  Total items:    ' + lines.reduce((a, l) => a + l.quantity, 0).toLocaleString() + '';
        txt += '  Item weight:    ' + (s.totalItemWeightGrams?.toFixed(2) ?? '?') + ' g  (' + ((s.totalItemWeightGrams ?? 0) / 453.592).toFixed(4) + ' lb)';
        txt += '  Shipment wt:    ' + (s.totalShipmentWeightGrams?.toFixed(2) ?? '?') + ' g  (' + (s.totalShipmentWeightLb?.toFixed(4) ?? '?') + ' lb)  incl. pkg factor';
        txt += '── Line Detail ───────────────────────────────────────────────────';
        (s.lines || []).forEach((line, i) => {
          const label = (lines[i]?.sku || ('Line ' + (i + 1))).padEnd(22);
          txt += '  ' + label + ' qty=' + line.quantity + '  ' + line.resolvedWeightGrams + ' g/unit  →  ' + (line.resolvedWeightGrams * line.quantity).toFixed(2) + ' g total';
        });
      }
      if (data.rates?.length) {
        txt += '── Carrier Rates ────────────────────────────────────────────────';
        data.rates.forEach(r => {
          txt += '  ' + r.carrier.toUpperCase().padEnd(8) + ' ' + r.serviceName.padEnd(34) + ' $' + (r.amountUsd?.toFixed(2) ?? '?.??') + ' ' + r.currency + '';
        });
      } else if (data.rates) {
        txt += '(No rates returned — check carrier config or destination.)';
      }
      out.textContent = txt;
    } catch (err) {
      out.textContent = 'Error: ' + err.message;
    } finally {
      btn.disabled = false; btn.textContent = 'Get Rates';
    }
  });
})();
</script>
<script>
// ── Package weight factor editor ─────────────────────────────────────────────
function startPackagingEdit() {
  document.getElementById('pkgPctDisplay').style.display = 'none';
  document.getElementById('pkgPctEditBtn').style.display = 'none';
  var ed = document.getElementById('pkgPctEdit');
  ed.style.display = 'flex';
  document.getElementById('pkgPctInput').focus();
}
function cancelPackagingEdit() {
  document.getElementById('pkgPctDisplay').style.display = '';
  document.getElementById('pkgPctEditBtn').style.display = '';
  document.getElementById('pkgPctEdit').style.display = 'none';
}
function savePackagingFactor() {
  var pct = parseFloat(document.getElementById('pkgPctInput').value);
  if (isNaN(pct) || pct < 0 || pct > 200) { alert('Enter a value between 0 and 200.'); return; }
  var factor = Math.round((1 + pct / 100) * 10000) / 10000;
  fetch('/api/settings').then(function(r){ return r.json(); }).then(function(s){
    s.packaging.packageWeightPct = factor;
    return fetch('/api/settings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(s)
    });
  }).then(function(r){
    if (r.ok) {
      var pctStr = pct % 1 === 0 ? pct.toFixed(0) : pct.toString();
      document.getElementById('pkgPctDisplay').innerHTML =
        '<strong>+' + pctStr + '%<\/strong> (factor: ' + factor + ')';
      cancelPackagingEdit();
    } else { alert('Save failed. Please try again.'); }
  }).catch(function(){ alert('Network error.'); });
}
</script>
<script>
// ── Page router ──────────────────────────────────────────────────────────────
(function() {
  const PAGES = ['overview','methods','rules','preview','weights','access'];
  const DEFAULT = 'overview';

  function getPage() {
    const hash = location.hash.replace('#','').trim();
    return PAGES.includes(hash) ? hash : DEFAULT;
  }

  function showPage(page) {
    PAGES.forEach(p => {
      const el = document.getElementById('page-' + p);
      if (el) el.style.display = (p === page) ? '' : 'none';
    });
    document.querySelectorAll('#pageNav .nav-link').forEach(a => {
      const href = a.getAttribute('href').replace('#','');
      a.classList.toggle('active', href === page);
    });
  }

  // Initial render
  showPage(getPage());

  // Hash changes (nav clicks)
  window.addEventListener('hashchange', () => showPage(getPage()));
})();
</script>
