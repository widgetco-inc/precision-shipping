<script>
// ── Nightly alert banner ──────────────────────────────────────────────────────
async function loadNightlyAlerts() {
  const res = await fetch('/api/weights/alerts');
  if (!res.ok) return;
  const { alert } = await res.json();
  const banner = document.getElementById('nightlyAlertBanner');
  if (!alert) return;
  if (alert.warnings.length === 0) {
    banner.style.display = 'none';
    return;
  }
  const ranAt = new Date(alert.ranAt).toLocaleString();
  banner.style.display = 'block';
  banner.innerHTML =
    '<strong>⚠ Nightly weight check (' + ranAt + '): ' + alert.warnings.length + ' issue(s) found</strong>' +
    '<ul>' +
    alert.warnings.map(w =>
      '<li class="warning-' + w.status + '"><strong>' + escHtml(w.productTitle) + ' — ' + escHtml(w.variantTitle) + '</strong>' +
      ' (' + escHtml(w.sku) + '): ' + escHtml(w.message) + '</li>'
    ).join('') +
    '</ul>';
}

// ── Weights sync ──────────────────────────────────────────────────────────────
async function loadSyncStatus() {
  const res = await fetch('/api/weights/sync-status');
  if (!res.ok) return;
  const data = await res.json();
  renderWeightsResult(data.result);
  if (data.inProgress) {
    document.getElementById('syncStatus').textContent = 'Sync in progress…';
    setTimeout(loadSyncStatus, 2000);
  }
}

function escHtml(str) {
  return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function renderWeightsResult(result) {
  if (!result) return;
  const warnings = result.warnings ?? [];
  const records  = result.records  ?? [];
  const statusEl = document.getElementById('syncStatus');
  statusEl.textContent = 'Last sync: ' + records.length + ' variants scanned, ' + warnings.length + ' warning(s)';

  const warnDiv = document.getElementById('syncWarnings');
  if (warnings.length) {
    warnDiv.innerHTML =
      '<ul class="warnings">' +
      warnings.map(w =>
        '<li class="warning-' + w.status + '"><strong>' + escHtml(w.productTitle) + ' — ' + escHtml(w.variantTitle) + '</strong>' +
        ' (' + escHtml(w.sku) + '): ' +
        (w.status === 'missing' ? 'true weight metafield not set' : escHtml(w.metafieldGrams) + 'g vs catalog ' + escHtml(w.shopifyCatalogGrams) + 'g') +
        '</li>'
      ).join('') +
      '</ul>';
  } else {
    warnDiv.innerHTML = '';
  }

  if (records.length) {
    const tbody = document.getElementById('weightsTableBody');
    tbody.innerHTML = records.map(r =>
      '<tr data-variant-id="' + r.variantId + '" class="status-' + r.status + '">' +
      '<td>' + escHtml(r.productTitle) + '</td>' +
      '<td>' + escHtml(r.variantTitle) + '</td>' +
      '<td>' + escHtml(r.sku) + '</td>' +
      '<td>' + r.shopifyCatalogGrams + '</td>' +
      '<td class="weight-cell">' +
        '<span class="weight-display">' + (r.metafieldGrams !== null ? r.metafieldGrams : '—') + '</span>' +
        '<input class="weight-input" type="number" step="0.0001" min="0.0001" value="' + (r.metafieldGrams ?? '') + '" style="display:none" />' +
      '</td>' +
      '<td><span class="pill ' + (r.status === 'ok' ? 'on' : 'off') + '">' + r.status.toUpperCase() + '</span></td>' +
      '<td>' +
        '<button class="btn-edit" type="button" onclick="startEditWeight(this)">Edit</button>' +
        '<button class="btn-save" type="button" onclick="saveWeight(this)" style="display:none">Save</button>' +
      '</td>' +
      '</tr>'
    ).join('');
    document.getElementById('weightsTable').style.display = '';
    applySkuFilter();
  }
}

function startEditWeight(btn) {
  const row = btn.closest('tr');
  row.querySelector('.weight-display').style.display = 'none';
  row.querySelector('.weight-input').style.display = '';
  row.querySelector('.btn-edit').style.display = 'none';
  row.querySelector('.btn-save').style.display = '';
}

async function saveWeight(btn) {
  const row = btn.closest('tr');
  const variantId = row.dataset.variantId;
  const input = row.querySelector('.weight-input');
  const grams = parseFloat(input.value);
  if (!grams || grams <= 0) { alert('Enter a valid weight in grams.'); return; }
  const res = await fetch('/api/weights/' + variantId, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ grams }),
  });
  if (!res.ok) { alert('Save failed.'); return; }
  row.querySelector('.weight-display').textContent = grams;
  row.querySelector('.weight-display').style.display = '';
  input.style.display = 'none';
  row.querySelector('.btn-edit').style.display = '';
  btn.style.display = 'none';
}

document.getElementById('syncWeightsBtn').addEventListener('click', async () => {
  const statusEl = document.getElementById('syncStatus');
  statusEl.textContent = 'Starting sync…';
  document.getElementById('syncWeightsBtn').disabled = true;
  const res = await fetch('/api/weights/sync', { method: 'POST' });
  if (!res.ok) { statusEl.textContent = 'Sync failed.'; document.getElementById('syncWeightsBtn').disabled = false; return; }
  statusEl.textContent = 'Sync running…';
  setTimeout(() => {
    document.getElementById('syncWeightsBtn').disabled = false;
    loadSyncStatus();
  }, 1500);
});

// ── SKU search / filter ───────────────────────────────────────────────────────
function applySkuFilter() {
  const q = document.getElementById('skuSearch').value.toLowerCase().trim();
  const rows = document.querySelectorAll('#weightsTableBody tr');
  rows.forEach(row => {
    if (!q) { row.style.display = ''; return; }
    const text = row.textContent.toLowerCase();
    row.style.display = text.includes(q) ? '' : 'none';
  });
}

document.getElementById('skuSearch').addEventListener('input', applySkuFilter);

// ── CSV import ────────────────────────────────────────────────────────────────
document.getElementById('csvUploadBtn').addEventListener('click', async () => {
  const fileInput = document.getElementById('csvFileInput');
  const resultPre = document.getElementById('csvResult');
  if (!fileInput.files || fileInput.files.length === 0) {
    alert('Please select a CSV file first.');
    return;
  }
  const file = fileInput.files[0];
  const csvText = await file.text();
  const btn = document.getElementById('csvUploadBtn');
  btn.disabled = true;
  btn.textContent = 'Importing…';
  resultPre.style.display = '';
  resultPre.textContent = 'Sending…';
  try {
    const res = await fetch('/api/weights/csv', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ csv: csvText }),
    });
    const data = await res.json();
    if (data.error) {
      resultPre.textContent = 'Error: ' + data.error;
    } else {
      resultPre.textContent =
        'Done: ' + data.succeeded + '/' + data.attempted + ' rows imported.' +
        (data.skipped > 0 ? ' ' + data.skipped + ' skipped.' : '') +
        (data.errors && data.errors.length > 0
          ? '\n\nIssues:\n' + data.errors.map(e => '  ' + e.sku + ': ' + e.reason).join('\n')
          : '');
      // Refresh the tables
      loadSyncStatus();
      loadUploadedWeightsTable();
    }
  } catch (err) {
    resultPre.textContent = 'Upload failed: ' + err.message;
  } finally {
    btn.disabled = false;
    btn.textContent = 'Upload & Import';
  }
});

// ── Uploaded weights table ───────────────────────────────────────────────────
async function loadUploadedWeightsTable() {
  const [uploadedRes, syncRes] = await Promise.allSettled([
    fetch('/api/weights/uploaded'),
    fetch('/api/weights/sync-status'),
  ]);

  let uploadedMap = {};
  if (uploadedRes.status === 'fulfilled' && uploadedRes.value.ok) {
    const d = await uploadedRes.value.json();
    if (Array.isArray(d)) {
      d.forEach(item => { uploadedMap[item.sku] = item.grams; });
    } else {
      uploadedMap = d;
    }
  }

  let metafieldMap = {};
  if (syncRes.status === 'fulfilled' && syncRes.value.ok) {
    const d = await syncRes.value.json();
    const records = (d.result && d.result.records) ? d.result.records : [];
    records.forEach(r => {
      if (r.sku) metafieldMap[r.sku] = r.metafieldGrams;
    });
  }

  const skus = Object.keys(uploadedMap);
  const empty = document.getElementById('uploadedWeightsEmpty');
  const table = document.getElementById('uploadedWeightsTable');
  const tbody = document.getElementById('uploadedWeightsTableBody');

  if (!skus.length) {
    empty.style.display = '';
    table.style.display = 'none';
    return;
  }

  empty.style.display = 'none';
  const rows = skus.sort().map(sku => {
    const uploaded = uploadedMap[sku];
    const shopify  = metafieldMap.hasOwnProperty(sku) ? metafieldMap[sku] : null;
    const match    = shopify !== null && Math.abs(uploaded - shopify) < 0.5;
    const statusHtml = shopify === null
      ? '<span title="No Shopify metafield found for this SKU" style="color:#f59e0b;font-size:16px">&#9900;</span>'
      : match
        ? '<span title="Weights match" style="color:#16a34a;font-size:16px">&#10003;</span>'
        : '<span title="Mismatch" style="color:#dc2626;font-size:16px">&#10007;</span>';
    return '<tr data-sku="' + escHtml(sku) + '">' +
      '<td><code>' + escHtml(sku) + '</code></td>' +
      '<td>' + uploaded + ' g</td>' +
      '<td>' + (shopify !== null ? shopify + ' g' : '<span class=\"muted\">\u2014</span>') + '</td>' +
      '<td style="font-size:18px;text-align:center">' + statusHtml + '</td>' +
      '<td style="text-align:center">' +
        '<label class="toggle-switch" title="Each unit ships in its own individual box">' +
          '<input type="checkbox" class="indiv-box-toggle" data-sku="' + escHtml(sku) + '"' +
          (isIndividualBox(sku) ? ' checked' : '') + '>' +
          '<span class="toggle-slider"></span>' +
        '</label>' +
      '</td>' +
      '<td style="text-align:center"><button class="btn-remove-sku" type="button" data-sku="' + escHtml(sku) + '" title="Remove discontinued SKU" style="background:none;border:none;cursor:pointer;color:var(--muted);font-size:14px;padding:3px 7px;border-radius:6px;line-height:1">&#10007;</button></td>' +
      '</tr>';
  });

  tbody.innerHTML = rows.join('');
  table.style.display = '';
  applyUploadedSkuFilter();
}

function applyUploadedSkuFilter() {
  const q = (document.getElementById('uploadedSkuSearch')?.value || '').toLowerCase().trim();
  const rows = document.querySelectorAll('#uploadedWeightsTableBody tr');
  rows.forEach(row => {
    if (!q) { row.style.display = ''; return; }
    row.style.display = row.dataset.sku?.toLowerCase().includes(q) ? '' : 'none';
  });
}

document.getElementById('uploadedSkuSearch')?.addEventListener('input', applyUploadedSkuFilter);

document.getElementById('uploadedWeightsTableBody')?.addEventListener('click', async (e) => {
  const btn = e.target.closest('.btn-remove-sku');
  if (!btn) return;
  const sku = btn.dataset.sku;
  if (!sku || !confirm('Remove "' + sku + '" from the uploaded weights list?')) return;
  btn.disabled = true;
  const res = await fetch('/api/weights/uploaded/' + encodeURIComponent(sku), { method: 'DELETE' });
  if (!res.ok) { alert('Failed to remove SKU.'); btn.disabled = false; return; }
  btn.closest('tr').remove();
  if (!document.querySelector('#uploadedWeightsTableBody tr')) {
    document.getElementById('uploadedWeightsTable').style.display = 'none';
    document.getElementById('uploadedWeightsEmpty').style.display = '';
  }
});

// ── Init ──────────────────────────────────────────────────────────────────────
loadSyncStatus();
loadNightlyAlerts();
loadUploadedWeightsTable();
</script>

<script>
// ── Individual-box SKU overrides ──────────────────────────────────────────
let _skuBoxOverrides = [];

async function loadSkuBoxOverrides() {
  try {
    const r = await fetch('/api/settings');
    const s = await r.json();
    _skuBoxOverrides = (s.packaging && s.packaging.skuBoxOverrides) ? s.packaging.skuBoxOverrides : [];
  } catch (e) {
    console.warn('[indiv-box] failed to load settings', e);
  }
}

function isIndividualBox(sku) {
  const upper = (sku || '').toUpperCase();
  return _skuBoxOverrides.some(function(ov) {
    return ov.shipsIndividually && upper.startsWith(ov.skuPrefix.toUpperCase());
  });
}

async function setIndividualBox(sku, enabled) {
  try {
    const r = await fetch('/api/settings');
    const s = await r.json();
    if (!s.packaging.skuBoxOverrides) s.packaging.skuBoxOverrides = [];
    const overrides = s.packaging.skuBoxOverrides;
    const idx = overrides.findIndex(function(ov) {
      return ov.skuPrefix.toUpperCase() === sku.toUpperCase();
    });
    if (enabled) {
      // Remove any existing entry for this SKU then add with shipsIndividually
      if (idx !== -1) overrides.splice(idx, 1);
      overrides.push({ skuPrefix: sku, shipsIndividually: true });
    } else {
      // Remove if present
      if (idx !== -1) overrides.splice(idx, 1);
    }
    await fetch('/api/settings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(s),
    });
    _skuBoxOverrides = overrides;
  } catch (e) {
    console.error('[indiv-box] save failed', e);
    alert('Failed to save individual box setting. Please try again.');
  }
}

// Wire up toggle clicks via event delegation on the uploaded weights table
document.addEventListener('change', function(e) {
  if (!e.target.classList.contains('indiv-box-toggle')) return;
  const sku = e.target.dataset.sku;
  const enabled = e.target.checked;
  e.target.disabled = true;
  setIndividualBox(sku, enabled).finally(function() {
    e.target.disabled = false;
  });
});

// Load overrides on page load so toggles render correctly
loadSkuBoxOverrides().then(function() {
  // Re-render the uploaded weights table so toggles show the correct state
  loadUploadedWeightsTable();
});
</script>

<script>
// ── Rate Estimator ──────────────────────────────────────────────────────────
(async function initEstimator() {
  const skuWeights = {}, skuList = [];
  try {
    const data = await fetch('/api/weights/uploaded').then(r => r.json());
    Object.entries(data).forEach(([sku, wg]) => {
      if (sku && typeof wg === 'number') { skuWeights[sku.toUpperCase()] = wg; skuList.push(sku); }
    });
  } catch (_) {}

  function esc(s) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  function getRows() { return Array.from(document.querySelectorAll('#estSkuRows .est-row')); }

  function updateTotals() {
    let totalQty = 0, totalG = 0;
    getRows().forEach(row => {
      const skuVal = row.querySelector('.est-sku-input').value.toUpperCase().trim();
      const qty    = parseInt(row.querySelector('.est-qty-input').value) || 0;
      let unitG    = skuWeights[skuVal];
      if (unitG === undefined) unitG = parseFloat(row.querySelector('.est-manual-weight').value) || 0;
      const rowG   = unitG * qty;
      row.querySelector('.est-row-total').textContent = (qty > 0 && unitG > 0) ? rowG.toFixed(2) + ' g' : '—';
      if (qty > 0 && unitG > 0) { totalQty += qty; totalG += rowG; }
    });
    document.getElementById('estTotalQty').textContent = totalQty.toLocaleString();
    document.getElementById('estTotalG').textContent   = totalG.toFixed(2) + ' g';
    document.getElementById('estTotalLb').textContent  = (totalG / 453.59237).toFixed(4) + ' lb';
    const L = parseFloat(document.getElementById('estBoxL').value) || 0;
    const W = parseFloat(document.getElementById('estBoxW').value) || 0;
    const H = parseFloat(document.getElementById('estBoxH').value) || 0;
    const boxEl = document.getElementById('estBoxDimDisplay');
    if (L > 0 && W > 0 && H > 0) {
      document.getElementById('estBoxDimText').textContent = L + '×' + W + '×' + H;
      boxEl.style.display = '';
    } else { boxEl.style.display = 'none'; }
  }

  function showAC(inp, dd) {
    const val = inp.value.toUpperCase().trim();
    dd.innerHTML = '';
    if (!val) { dd.style.display = 'none'; return; }
    const matches = skuList.filter(s => s.toUpperCase().includes(val)).slice(0, 20);
    if (!matches.length) { dd.style.display = 'none'; return; }
    matches.forEach(sku => {
      const item = document.createElement('div');
      item.className = 'est-ac-item';
      const w = skuWeights[sku.toUpperCase()];
      item.innerHTML = '<span>' + esc(sku) + '</span><span class="est-ac-wt">' + (w !== undefined ? w + ' g' : '') + '</span>';
      item.addEventListener('mousedown', e => {
        e.preventDefault();
        inp.value = sku; dd.style.display = 'none';
        const row = inp.closest('.est-row');
        const unit = row.querySelector('.est-unit-g');
        const manual = row.querySelector('.est-manual-weight');
        if (w !== undefined) { unit.textContent = w + ' g'; unit.className = 'est-unit-g found'; manual.style.display = 'none'; }
        else { unit.textContent = 'Not found — enter g:'; unit.className = 'est-unit-g'; manual.style.display = ''; }
        updateTotals();
        row.querySelector('.est-qty-input').focus();
      });
      dd.appendChild(item);
    });
    dd.style.display = 'block';
  }

  let rowCount = 0;
  function addRow(skuVal, qtyVal) {
    skuVal = skuVal || ''; qtyVal = qtyVal || '';
    const id  = ++rowCount;
    const sku = skuVal.toUpperCase().trim();
    const w   = skuWeights[sku];
    const found = typeof w === 'number';
    const row = document.createElement('div');
    row.className = 'est-row'; row.setAttribute('data-row', id);
    row.innerHTML =
      '<div class="est-sku-wrap">' +
        '<input type="text" class="est-sku-input" placeholder="SKU" value="' + esc(skuVal) + '" autocomplete="off" />' +
        '<div class="est-ac"></div>' +
      '</div>' +
      '<input type="number" class="est-qty-input" value="' + qtyVal + '" min="0" step="1" />' +
      '<span class="est-unit-g' + (found ? ' found' : '') + '">' + (found ? w + ' g' : (skuVal ? 'Not found — enter g:' : '—')) + '</span>' +
      '<input type="number" class="est-manual-weight" step="0.0001" min="0.0001" placeholder="g" style="display:' + (!found && skuVal ? '' : 'none') + '" />' +
      '<span class="est-row-total">—</span>' +
      '<button class="est-remove-btn" type="button">✕</button>';
    document.getElementById('estSkuRows').appendChild(row);
    const inp = row.querySelector('.est-sku-input');
    const dd  = row.querySelector('.est-ac');
    const unit = row.querySelector('.est-unit-g');
    const manual = row.querySelector('.est-manual-weight');
    inp.addEventListener('input', () => {
      showAC(inp, dd);
      const s = inp.value.toUpperCase().trim(), wt = skuWeights[s];
      if (!s)      { unit.textContent = '—'; unit.className = 'est-unit-g'; manual.style.display = 'none'; }
      else if (wt !== undefined) { unit.textContent = wt + ' g'; unit.className = 'est-unit-g found'; manual.style.display = 'none'; }
      else         { unit.textContent = 'Not found — enter g:'; unit.className = 'est-unit-g'; manual.style.display = ''; }
      updateTotals();
    });
    inp.addEventListener('focus', () => showAC(inp, dd));
    inp.addEventListener('blur',  () => setTimeout(() => { dd.style.display = 'none'; }, 150));
    inp.addEventListener('keydown', e => { if (e.key === 'Tab' || e.key === 'Enter') dd.style.display = 'none'; });
    row.querySelector('.est-qty-input').addEventListener('input', updateTotals);
    manual.addEventListener('input', updateTotals);
    row.querySelector('.est-remove-btn').addEventListener('click', () => { row.remove(); updateTotals(); });
    updateTotals();
    if (!skuVal) inp.focus();
  }

  ['estBoxL','estBoxW','estBoxH'].forEach(id => document.getElementById(id).addEventListener('input', updateTotals));

  addRow();
  document.getElementById('estAddRow').addEventListener('click', () => addRow());

  document.getElementById('estRunBtn').addEventListener('click', async () => {
    const btn  = document.getElementById('estRunBtn');
    const reEl = document.getElementById('estResults');
    const out  = document.getElementById('estOut');
    const cc   = (document.getElementById('estCountry').value.trim() || 'US').toUpperCase();
    const zip  = document.getElementById('estToZip').value.trim();
    const lines = [];
    getRows().forEach(row => {
      const s   = row.querySelector('.est-sku-input').value.toUpperCase().trim();
      const qty = parseInt(row.querySelector('.est-qty-input').value) || 0;
      let wg    = skuWeights[s];
      if (wg === undefined) wg = parseFloat(row.querySelector('.est-manual-weight').value) || 0;
      if (qty > 0 && wg > 0) lines.push({ sku: s || undefined, quantity: qty, trueWeightGrams: wg });
    });
    if (!lines.length) { reEl.style.display = ''; out.textContent = 'Add at least one SKU with a valid weight.'; return; }
    btn.disabled = true; btn.textContent = 'Getting rates…';
    reEl.style.display = ''; out.textContent = 'Calculating…';
    try {
      const data = await fetch('/api/preview', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ destination: { countryCode: cc, postalCode: zip }, fromZip: document.getElementById('estFromZip').value.trim() || undefined, isResidential: document.getElementById('estResidential').checked || undefined, lines })
      }).then(r => r.json());
      const s = data.shipment;
      const fromZip = document.getElementById('estFromZip').value.trim();
      const L = parseFloat(document.getElementById('estBoxL').value) || 0;
      const W = parseFloat(document.getElementById('estBoxW').value) || 0;
      const H = parseFloat(document.getElementById('estBoxH').value) || 0;
      let html = '';

      // Shipment summary
      if (s) {
        html += '<div class="est-results-summary"><table>';
        if (fromZip) html += '<tr><td>From</td><td>' + esc(fromZip) + '</td></tr>';
        html += '<tr><td>To</td><td>' + esc((zip || '—') + ', ' + cc) + '</td></tr>';
        if (L > 0 && W > 0 && H > 0) html += '<tr><td>Box</td><td>' + L + ' × ' + W + ' × ' + H + '</td></tr>';
        html += '<tr><td>Items</td><td>' + lines.reduce((a, l) => a + l.quantity, 0).toLocaleString() + '</td></tr>';
        html += '<tr><td>Item weight</td><td>' + (s.totalItemWeightGrams?.toFixed(2) ?? '—') + ' g (' + ((s.totalItemWeightGrams ?? 0) / 453.592).toFixed(4) + ' lb)</td></tr>';
        html += '<tr><td>Package weight (5%)</td><td>' + (s.packageWeightGrams?.toFixed(2) ?? '—') + ' g (' + ((s.packageWeightGrams ?? 0) / 453.592).toFixed(4) + ' lb)</td></tr>';
        html += '<tr><td><strong>Shipment weight</strong></td><td><strong>' + (s.totalShipmentWeightGrams?.toFixed(2) ?? '—') + ' g (' + (s.totalShipmentWeightLb?.toFixed(4) ?? '—') + ' lb)</strong></td></tr>';
        html += '</table></div>';
      }

      // Rate cards
      if (data.rates && data.rates.length) {
        html += '<div class="est-rates-label">Carrier Rates</div>';
        html += '<div class="est-rates-list">';
                // Bucket rates: cheapest Ground, cheapest 2-Day, cheapest 2 Next-Day
        var _ground = [], _twoDay = [], _nextDay = [];
        data.rates.forEach(function(r) {
          var sc = r.serviceCode || '';
          if (['FEDEX_GROUND','GROUND_HOME_DELIVERY','GROUND','GROUND_SAVER'].indexOf(sc) >= 0) { _ground.push(r); }
          else if (['FEDEX_2_DAY','SECOND_DAY_AIR'].indexOf(sc) >= 0) { _twoDay.push(r); }
          else if (['PRIORITY_OVERNIGHT','STANDARD_OVERNIGHT','NEXT_DAY_AIR','NEXT_DAY_AIR_SAVER','FIRST_OVERNIGHT'].indexOf(sc) >= 0) { _nextDay.push(r); }
        });
        function _cheapest(arr) { return arr.slice().sort(function(a,b){return (a.amountUsd||0)-(b.amountUsd||0);})[0]; }
        var _shown = [];
        var _g = _cheapest(_ground); if (_g) _shown.push(_g);
        var _t = _cheapest(_twoDay); if (_t) _shown.push(_t);
        _nextDay.sort(function(a,b){return (a.amountUsd||0)-(b.amountUsd||0);});
        _shown = _shown.concat(_nextDay.slice(0,2));
        _shown.forEach(function(r) {
          const price = r.amountUsd != null ? '$' + r.amountUsd.toFixed(2) : '—';
          html += '<div class="est-rate-card">';
          html += '<span class="est-rate-carrier"><img src="https://assets.easypost.com/assets/images/carrier-logos/' + r.carrier.toLowerCase() + '.png" alt="' + esc(r.carrier.toUpperCase()) + '" onerror="this.style.display=\'none\';this.parentNode.innerHTML=\'' + esc(r.carrier.toUpperCase()) + '\'"></span>';
          html += '<span class="est-rate-service">' + esc(r.serviceName || r.service || '') + '</span>';
          
            (function() {
              // FedEx/UPS observed holidays (M/D) — weekends auto-skipped
              const bizHolidays = BIZ_HOLIDAYS.map(function(h){return h.date;});
              function nextBizDay(d) {
                const nd = new Date(d);
                while (true) {
                  const dow = nd.getDay();
                  if (!SHIP_SCHEDULE[(dow + 6) % 7].ships) { nd.setDate(nd.getDate()+1); continue; }
                  if (bizHolidays.includes((nd.getMonth()+1)+'/'+nd.getDate())) { nd.setDate(nd.getDate()+1); continue; }
                  break;
                }
                return nd;
              }
              function addBizDays(start, n) {
                const d = new Date(start); let c = 0;
                while (c < n) {
                  d.setDate(d.getDate()+1);
                  const dow = d.getDay();
                  if (!SHIP_SCHEDULE[(dow + 6) % 7].ships) continue;
                  if (bizHolidays.includes((d.getMonth()+1)+'/'+d.getDate())) continue;
                  c++;
                }
                return d;
              }
              if (r.estDeliveryDays != null) {
                const ship = nextBizDay(new Date());
                const arr = addBizDays(ship, r.estDeliveryDays);
                const dn = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
                const mn = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
                const lbl = r.estDeliveryDays + ' day' + (r.estDeliveryDays !== 1 ? 's' : '') + ' (' + dn[arr.getDay()] + ' ' + mn[arr.getMonth()] + ' ' + arr.getDate() + ')';
                html += '<span class="est-rate-days">' + lbl + '</span>';
              } else {
                html += '<span class="est-rate-days">—</span>';
              }
            })();
          html += '<span class="est-rate-price">' + esc(price) + '</span>';
          html += '</div>';
        
        });
        html += '</div>';
      } else if (data.rates) {
        html += '<div class="est-no-rates">No rates returned — check carrier credentials or destination.</div>';
      }

      out.innerHTML = html;
    } catch (err) {
      out.textContent = 'Error: ' + err.message;
    } finally {
      btn.disabled = false; btn.textContent = 'Get Rates';
    }
  });
})();
</script>
<script>
// ── Package weight factor editor ─────────────────────────────────────────────
function startPackagingEdit() {
  document.getElementById('pkgPctDisplay').style.display = 'none';
  document.getElementById('pkgPctEditBtn').style.display = 'none';
  var ed = document.getElementById('pkgPctEdit');
  ed.style.display = 'flex';
  document.getElementById('pkgPctInput').focus();
}
function cancelPackagingEdit() {
  document.getElementById('pkgPctDisplay').style.display = '';
  document.getElementById('pkgPctEditBtn').style.display = '';
  document.getElementById('pkgPctEdit').style.display = 'none';
}
function savePackagingFactor() {
  var pct = parseFloat(document.getElementById('pkgPctInput').value);
  if (isNaN(pct) || pct < 0 || pct > 200) { alert('Enter a value between 0 and 200.'); return; }
  var factor = Math.round((1 + pct / 100) * 10000) / 10000;
  fetch('/api/settings').then(function(r){ return r.json(); }).then(function(s){
    s.packaging.packageWeightPct = factor;
    return fetch('/api/settings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(s)
    });
  }).then(function(r){
    if (r.ok) {
      var pctStr = pct % 1 === 0 ? pct.toFixed(0) : pct.toString();
      document.getElementById('pkgPctDisplay').innerHTML =
        '<strong>+' + pctStr + '%<\/strong> (factor: ' + factor + ')';
      cancelPackagingEdit();
    } else { alert('Save failed. Please try again.'); }
  }).catch(function(){ alert('Network error.'); });
}
</script>
<script>
// ── Page router ──────────────────────────────────────────────────────────────
(function() {
  const PAGES = ['overview','methods','rules','preview','weights','access','orders','packages'];
  const DEFAULT = 'overview';

  function getPage() {
    const hash = location.hash.replace('#','').trim();
    return PAGES.includes(hash) ? hash : DEFAULT;
  }

  function showPage(page) {
    PAGES.forEach(p => {
      const el = document.getElementById('page-' + p);
      if (el) el.style.display = (p === page) ? '' : 'none';
    });
    document.querySelectorAll('#pageNav .nav-link').forEach(a => {
      const href = a.getAttribute('href').replace('#','');
      a.classList.toggle('active', href === page);
    });
  }

  // Initial render
  showPage(getPage());

  // Hash changes (nav clicks)
  window.addEventListener('hashchange', () => showPage(getPage()));
})();

// ── Orders ─────────────────────────────────────────────────────────────────
async function loadOrders() {
  const esc = s => String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  const list    = document.getElementById('orders-list');
  const loading = document.getElementById('orders-state-loading');    if (document.getElementById('orders-count-badge')) document.getElementById('orders-count-badge').textContent = '…';

  const empty   = document.getElementById('orders-state-empty');
  const errBox  = document.getElementById('orders-state-error');
  const updated = document.getElementById('orders-last-updated');
  if (!list) return;

  list.innerHTML = '';
  if (loading) loading.style.display = 'block';
  if (empty)   empty.style.display   = 'none';
  if (errBox)  errBox.style.display  = 'none';

  try {
    const resp = await fetch('/api/orders');
    const data = await resp.json();

    if (loading) loading.style.display = 'none';

    if (data.error) {
      if (errBox) { errBox.textContent = 'Error: ' + data.error; errBox.style.display = 'block'; }
      return;
    }

    const orders = data.orders || [];    const badge = document.getElementById('orders-count-badge');
    if (badge) badge.textContent = String(orders.length);

    if (updated) updated.textContent = 'Last updated: ' + new Date().toLocaleTimeString();

    if (orders.length === 0) {
      if (empty) empty.style.display = 'block';
      return;
    }

    orders.forEach(function(o) {
      var card = document.createElement('div');
      card.style.cssText = 'border:1px solid var(--line);border-radius:10px;padding:14px 18px;background:#fff;font-size:13px';

      var itemLines = (o.line_items || []).slice(0, 3).map(function(li) {
        return '<span style="display:inline-block;background:var(--bg);border-radius:4px;padding:2px 8px;margin:2px 4px 2px 0;font-size:12px">'
          + esc(li.name) + ' &times; ' + li.quantity + '</span>';
      }).join('');
      if ((o.line_items || []).length > 3) {
        itemLines += '<span style="color:var(--muted);font-size:12px">+' + (o.line_items.length - 3) + ' more</span>';
      }

      var addr = o.shipping_address || {};
      var addrStr = [addr.name, addr.city, addr.province_code, addr.country_code].filter(Boolean).join(', ');

      var createdAt = o.created_at ? new Date(o.created_at).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) : '';
      var updatedAt = o.updated_at ? new Date(o.updated_at).toLocaleString('en-US', { month:'short', day:'numeric', hour:'numeric', minute:'2-digit' }) : '';

      card.innerHTML =
        '<div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap">' +
          '<div>' +
            '<span style="font-weight:700;font-size:14px">' + esc(o.name) + '</span>' +
            '<span style="color:var(--muted);margin-left:10px;font-size:12px">' + createdAt + '</span>' +
            (o.updated_at !== o.created_at ? '<span style="color:var(--muted);margin-left:6px;font-size:11px">(edited ' + updatedAt + ')</span>' : '') +
          '</div>' +
          '<div style="display:flex;gap:8px;align-items:center">' +
            '<span style="background:#fef3c7;color:#92400e;font-size:11px;font-weight:700;padding:3px 8px;border-radius:999px;text-transform:uppercase;letter-spacing:.04em">Unfulfilled</span>' +
            '<span style="font-weight:600;font-size:14px">$' + parseFloat(o.total_price || 0).toFixed(2) + '</span>' +
          '</div>' +
        '</div>' +
        '<div style="margin-top:8px;color:var(--muted);font-size:12px">&#128344; Ship to: <span style="color:var(--text)">' + esc(addrStr) + '</span></div>' +
        '<div style="margin-top:8px">' + itemLines + '</div>';

      list.appendChild(card);
    });
  } catch (err) {
    if (loading) loading.style.display = 'none';
    if (errBox)  { errBox.textContent = 'Failed to load orders: ' + err.message; errBox.style.display = 'block'; }
  }
}

// Auto-load when navigating to Orders page
(function() {
  const origShowPage = window._showPage;
  window._ordersLoaded = false;
  // Hook into hash change
  window.addEventListener('hashchange', function() {
    if (location.hash === '#orders' && !window._ordersLoaded) {
      window._ordersLoaded = true;
      loadOrders();
    }
    if (location.hash === '#packages' && !window._packagesLoaded) {
      window._packagesLoaded = true;
      loadPackages();
    }
  });
  if (location.hash === '#orders') loadOrders();
  if (location.hash === '#packages') loadPackages();
})();


    // ── Packages Page ────────────────────────────────────────────────────────
    let _packages = [];
    let _editPkgId = null;

    async function loadPackages() {
      try {
        const r = await fetch('/api/packages');
        const data = await r.json();
        _packages = Array.isArray(data) ? data : [];
        renderPackageTable();
        populatePkgDropdown();
      } catch(e) {
        console.error('[packages] load error', e);
      }
    }

    function renderPackageTable() {
      const tbody = document.getElementById('pkg-table-body');
      if (!tbody) return;
      if (_packages.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:#888;padding:1.5rem">No packages yet. Click + Add Package to get started.</td></tr>';
        return;
      }
      tbody.innerHTML = _packages.map(p =>
        '<tr>' +
        '<td>' + escHtml(p.name) + '</td>' +
        '<td>' + (p.length_in != null ? p.length_in + '"' : '—') + '</td>' +
        '<td>' + (p.width_in != null ? p.width_in + '"' : '—') + '</td>' +
        '<td>' + (p.height_in != null ? p.height_in + '"' : '—') + '</td>' +
        '<td style="text-align:right">' +
          '<button class="btn-small" style="margin-right:.35rem" onclick="editPackage(' + p.id + ')">Edit</button>' +
          '<button class="btn-small btn-danger" onclick="deletePackage(' + p.id + ')">Delete</button>' +
        '</td>' +
        '</tr>'
      ).join('');
    }

    function populatePkgDropdown() {
      const sel = document.getElementById('estPkgSelect');
      if (!sel) return;
      const prev = sel.value;
      sel.innerHTML = '<option value="">— Manual / enter dimensions below —</option>';
      _packages.forEach(p => {
        const opt = document.createElement('option');
        opt.value = p.id;
        opt.textContent = p.name + '  (' + p.length_in + ' × ' + p.width_in + ' × ' + p.height_in + ' in)';
        sel.appendChild(opt);
      });
      if (prev) sel.value = prev;
    }

    // Estimator dropdown → auto-fill L×W×H
    document.addEventListener('DOMContentLoaded', function() {
      var sel = document.getElementById('estPkgSelect');
      if (sel) {
        sel.addEventListener('change', function() {
          var pkg = _packages.find(p => String(p.id) === sel.value);
          var lEl = document.getElementById('estBoxL');
          var wEl = document.getElementById('estBoxW');
          var hEl = document.getElementById('estBoxH');
          if (pkg && lEl && wEl && hEl) {
            lEl.value = pkg.length_in;
            wEl.value = pkg.width_in;
            hEl.value = pkg.height_in;
          } else if (!pkg && lEl && wEl && hEl) {
            lEl.value = '';
            wEl.value = '';
            hEl.value = '';
          }
        });
      }
      // Load packages on startup for estimator dropdown
      loadPackages();
    });

    function showAddPackageForm() {
      _editPkgId = null;
      document.getElementById('pkg-form-title').textContent = 'Add Package';
      document.getElementById('pkgFormName').value = '';
      document.getElementById('pkgFormL').value = '';
      document.getElementById('pkgFormW').value = '';
      document.getElementById('pkgFormH').value = '';
      document.getElementById('pkg-form-error').style.display = 'none';
      document.getElementById('pkg-form-wrapper').style.display = '';
      document.getElementById('pkgFormName').focus();
    }

    function editPackage(id) {
      var pkg = _packages.find(p => p.id === id);
      if (!pkg) return;
      _editPkgId = id;
      document.getElementById('pkg-form-title').textContent = 'Edit Package';
      document.getElementById('pkgFormName').value = pkg.name;
      document.getElementById('pkgFormL').value = pkg.length_in ?? '';
      document.getElementById('pkgFormW').value = pkg.width_in ?? '';
      document.getElementById('pkgFormH').value = pkg.height_in ?? '';
      document.getElementById('pkg-form-error').style.display = 'none';
      document.getElementById('pkg-form-wrapper').style.display = '';
      document.getElementById('pkgFormName').focus();
    }

    function cancelPackageForm() {
      document.getElementById('pkg-form-wrapper').style.display = 'none';
      _editPkgId = null;
    }

    async function savePackage() {
      var name = document.getElementById('pkgFormName').value.trim();
      var l = document.getElementById('pkgFormL').value;
      var w = document.getElementById('pkgFormW').value;
      var h = document.getElementById('pkgFormH').value;
      var errEl = document.getElementById('pkg-form-error');
      errEl.style.display = 'none';

      if (!name) {
        errEl.textContent = 'Package name is required.';
        errEl.style.display = '';
        return;
      }

      try {
        var url = _editPkgId ? '/api/packages/' + _editPkgId : '/api/packages';
        var method = _editPkgId ? 'PUT' : 'POST';
        var r = await fetch(url, {
          method: method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: name, length_in: l !== '' ? parseFloat(l) : null, width_in: w !== '' ? parseFloat(w) : null, height_in: h !== '' ? parseFloat(h) : null })
        });
        var data = await r.json();
        if (data.error) {
          errEl.textContent = data.error;
          errEl.style.display = '';
          return;
        }
        cancelPackageForm();
        await loadPackages();
      } catch(e) {
        errEl.textContent = 'Save failed: ' + e.message;
        errEl.style.display = '';
      }
    }

    async function deletePackage(id) {
      if (!confirm('Delete this package?')) return;
      try {
        var r = await fetch('/api/packages/' + id, { method: 'DELETE' });
        var data = await r.json();
        if (data.error) { alert(data.error); return; }
        await loadPackages();
      } catch(e) {
        alert('Delete failed: ' + e.message);
      }
    }

    if (location.hash === '#packages') loadPackages();
</script>
</body>
</html>
