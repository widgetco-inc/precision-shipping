<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In | Ship</title>
    <link rel="stylesheet" href="/styles.css" />
    <style>
      body { display:flex; align-items:center; justify-content:center; min-height:100vh; background:#f5f5f7; margin:0; }
      .login-box { background:#fff; border-radius:12px; box-shadow:0 2px 16px rgba(0,0,0,0.10); padding:2.5rem 2.5rem 2rem; width:100%; max-width:380px; }
      .login-logo { text-align:center; margin-bottom:1.2rem; }
      .login-logo h1 { font-size:1.4rem; font-weight:700; color:#1a1a2e; margin:0; }
      .login-logo p { font-size:0.85rem; color:#888; margin:0.2rem 0 0; }
      .form-group { margin-bottom:1rem; }
      .form-group label { display:block; font-size:0.85rem; font-weight:600; color:#444; margin-bottom:0.3rem; }
      .form-group input { width:100%; padding:0.55rem 0.75rem; border:1px solid #ddd; border-radius:7px; font-size:0.95rem; box-sizing:border-box; }
      .btn-login { width:100%; padding:0.65rem; background:#1a1a2e; color:#fff; border:none; border-radius:7px; font-size:1rem; font-weight:600; cursor:pointer; margin-top:0.5rem; }
      .btn-login:hover { background:#2d2d50; }
      .error-msg { background:#fff0f0; color:#c0392b; border:1px solid #f5c6cb; border-radius:6px; padding:0.6rem 0.9rem; font-size:0.88rem; margin-bottom:1rem; }
    </style>
  </head>
  <body>
    <div class="login-box">
      <div class="login-logo">
        <h1>Ship</h1>
      </div>
      <% if (error) { %>
        <div class="error-msg"><%= error %></div>
      <% } %>
      <form method="POST" action="/login">
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" required autofocus value="<%= prefill || '' %>" />
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" required />
        </div>
        <button type="submit" class="btn-login">Sign In</button>
      </form>
    </div>
  </body>
</html>
