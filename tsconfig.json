{
    "compilerOptions": {
          "target": "ES2022",
          "module": "CommonJS",
          "moduleResolution": "Node",
          "rootDir": "src",
          "outDir": "dist",
          "strict": false,
          "noImplicitAny": false,
          "esModuleInterop": true,
          "forceConsistentCasingInFileNames": true,
          "skipLibCheck": true,
          "resolveJsonModule": true
    },
    "include": ["src/**/*.ts"]
}
